@model IEnumerable<LMS.Ovncr.Models.TbKichBan>
    


<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📑 Quản lý kịch bản diễn tập</h2>
        <a asp-action="Create" class="btn btn-success">+ Thêm kịch bản mới</a>
    </div>

    <table class="table table-hover border shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Mã KB</th>
                <th>Tên kịch bản</th>
                <th>Mục tiêu</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
            <tr>
                <td>@item.IdKichBan</td>
                <td><span class="badge bg-secondary">@item.MaKichBan</span></td>
                <td><strong>@item.TenKichBan</strong></td>
                <td class="text-muted">@item.MucTieu</td>
                <td class="text-center">
                    <button class="btn btn-sm btn-outline-primary">Sửa</button>
                    <button class="btn btn-sm btn-outline-danger">Xóa</button>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>