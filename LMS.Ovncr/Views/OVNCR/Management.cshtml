@model IEnumerable<LMS.Ovncr.Models.Scenario>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📑 Quản lý kịch bản diễn tập</h2>
        <button class="btn btn-success">+ Thêm kịch bản mới</button>
    </div>

    <table class="table table-hover border">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên kịch bản</th>
                <th>Loại</th>
                <th>Độ khó</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
            <tr>
                <td>@item.Id</td>
                <td><strong>@item.Name</strong></td>
                <td><span class="badge bg-info">@item.Category</span></td>
                <td>@item.Difficulty</td>
                <td>@(item.IsActive ? "✅ Sẵn sàng" : "❌ Đang khóa")</td>
                <td>
                    <button class="btn btn-sm btn-outline-primary">Sửa</button>
                    <button class="btn btn-sm btn-outline-danger">Xóa</button>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>