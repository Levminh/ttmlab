@model LMS.Ovncr.ViewModels.EditProfileViewModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0">👤 Thông tin cá nhân</h5>
        </div>
        <div class="card-body p-4">

            <!-- Hiển thị thông báo thành công -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    ✅ @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Hiện thị lỗi -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <!-- Form cập nhật thông tin cá nhân -->
            <form asp-action="Profile" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <!-- Tên đăng nhập: chỉ xem, không cho sửa -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Tên đăng nhập</label>
                    <input type="text" class="form-control bg-light" value="@Model.UserName" readonly />
                    <div class="form-text">Tên đăng nhập không thể thay đổi.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold">Họ và tên</label>
                    <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên..." />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="PhoneNumber" class="form-label fw-semibold">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="0901234567" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">💾 Lưu thay đổi</button>
                    <a asp-action="ChangePassword" asp-controller="Account" class="btn btn-outline-secondary px-4">🔑 Đổi mật khẩu</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
