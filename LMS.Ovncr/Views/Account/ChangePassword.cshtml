@model LMS.Ovncr.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container py-4" style="max-width: 500px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <h5 class="mb-0">🔑 Đổi mật khẩu</h5>
        </div>
        <div class="card-body p-4">

            <!-- Thông báo thành công -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    ✅ @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Hiển thị lỗi -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <!-- Form đổi mật khẩu -->
            <form asp-action="ChangePassword" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label fw-semibold">Mật khẩu hiện tại</label>
                    <input asp-for="CurrentPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại" />
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>

                <hr />

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold">Mật khẩu mới</label>
                    <input asp-for="NewPassword" class="form-control" placeholder="Tối thiểu 6 ký tự" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmNewPassword" class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                    <input asp-for="ConfirmNewPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning px-4 fw-semibold">🔒 Đổi mật khẩu</button>
                    <a asp-action="Profile" asp-controller="Account" class="btn btn-outline-secondary px-4">← Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
