@model List<LMS.Ovncr.ViewModels.UserListViewModel>
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<div class="row align-items-center mb-4">
    <div class="col-md-4 mb-3 mb-md-0">
        <h4 class="mb-1">👥 Quản lý tài khoản</h4>
        <p class="text-muted mb-0">Hiển thị: <strong>@Model.Count</strong> tài khoản</p>
    </div>
    <div class="col-md-4 mb-3 mb-md-0">
        <form method="get" asp-action="Users" asp-controller="Admin" class="d-flex">
            <input type="text" name="search" class="form-control me-2" 
                   placeholder="Tìm username, email, tên..." 
                   value="@ViewData["SearchQuery"]" />
            <button class="btn btn-outline-secondary" type="submit">🔍</button>
            @if (ViewData["SearchQuery"] != null)
            {
                <a asp-action="Users" class="btn btn-link text-decoration-none text-muted">Hủy</a>
            }
        </form>
    </div>
    <div class="col-md-4 text-md-end">
        <a asp-action="CreateUser" asp-controller="Admin" class="btn btn-primary shadow-sm">
            ➕ Tạo tài khoản mới
        </a>
    </div>
</div>

<!-- Thông báo thành công / thất bại -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        ✅ @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        ❌ @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Bảng danh sách người dùng -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Tên đăng nhập</th>
                        <th scope="col">Họ và tên</th>
                        <th scope="col">Email</th>
                        <th scope="col">Vai trò</th>
                        <th scope="col">Trạng thái</th>
                        <th scope="col" class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Chưa có tài khoản nào.</td>
                        </tr>
                    }
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var user = Model[i];
                        <tr>
                            <td class="text-muted">@(i + 1)</td>
                            <td><strong>@user.UserName</strong></td>
                            <td>@(user.FullName ?? "—")</td>
                            <td>@(user.Email ?? "—")</td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    var badgeColor = role switch {
                                        "Admin" => "danger",
                                        "Teacher" => "warning text-dark",
                                        "Student" => "secondary",
                                        _ => "secondary"
                                    };
                                    var displayRole = role switch {
                                        "Teacher" => "Giảng viên",
                                        "Student" => "Học viên",
                                        _ => role
                                    };
                                    <span class="badge bg-@badgeColor">@displayRole</span>
                                }
                                @if (!user.Roles.Any()) { <span class="text-muted">—</span> }
                            </td>
                            <td>
                                @if (user.IsLockedOut)
                                {
                                    <span class="badge bg-danger">🔒 Đang khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">✅ Hoạt động</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <!-- Sửa thông tin -->
                                    <a asp-action="EditUser" asp-controller="Admin"
                                       asp-route-id="@user.Id"
                                       class="btn btn-outline-primary" title="Sửa">✏️</a>

                                    <!-- Khóa / Mở khóa -->
                                    <form asp-action="ToggleLockout" asp-controller="Admin"
                                          asp-route-id="@user.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('@(user.IsLockedOut ? "Bạn có muốn mở khóa tài khoản này?" : "Bạn có muốn khóa tài khoản này?")')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn @(user.IsLockedOut ? "btn-outline-success" : "btn-outline-warning")"
                                                title="@(user.IsLockedOut ? "Mở khóa" : "Khóa tài khoản")">
                                            @(user.IsLockedOut ? "🔓" : "🔒")
                                        </button>
                                    </form>

                                    <!-- Xóa tài khoản -->
                                    <form asp-action="DeleteUser" asp-controller="Admin"
                                          asp-route-id="@user.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn XÓA tài khoản @user.UserName? Hành động này không thể hoàn tác!')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger" title="Xóa">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
