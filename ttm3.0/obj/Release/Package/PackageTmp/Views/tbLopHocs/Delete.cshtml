@model ttm3._0.Models.tbLopHoc

@{
    ViewBag.Title = "Xóa lớp học";
}
<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
<div class="card shadow mb-4">
    <div class="card-header">
        <h3>@ViewBag.Title</h3>
        <h4>Bạn có chắc chắn muốn xóa?</h4>
    </div>
    <div class="card-body">
        <div>
            <h4>tbLopHoc</h4>
            <hr />
            <dl class="dl-horizontal">
                <dt>
                    @Html.DisplayNameFor(model => model.LopHoc)
                </dt>

                <dd>
                    @Html.DisplayFor(model => model.LopHoc)
                </dd>

                <dt>
                    @Html.DisplayNameFor(model => model.ThongTin)
                </dt>

                <dd>
                    @Html.DisplayFor(model => model.ThongTin)
                </dd>
            </dl>
        </div>
    </div>
    <div class="card-footer">
        @using (Html.BeginForm())
            {
            @Html.AntiForgeryToken()

            <div class="form-actions no-color">
                <input type="submit" value="Xóa" class="btn btn-primary" /> |
                @Html.ActionLink("Quay lại", "Index")
            </div>
        }
    </div>
</div>
