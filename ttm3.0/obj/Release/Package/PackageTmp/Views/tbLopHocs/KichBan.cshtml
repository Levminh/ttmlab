@model IEnumerable<ttm3._0.Models.tbLopHocKichBan>

@{
    ViewBag.Title = "Danh sách kịch bản trong lớp";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />
<div class="card shadow mb-4">
    <div class="card-header">
        <h3>@ViewBag.Title</h3>
        <p>
            @Html.ActionLink("Thêm kịch bản vào lớp", "KichBanAdd", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "btn btn-success" }) |
            @Html.ActionLink("Cài đặt lại tất cả các máy", "CaiDatMay", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "btn btn-success" }) |
            @Html.ActionLink("Bật tất cả các máy", "BatMay", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "btn btn-success" }) |
            @Html.ActionLink("Tất tất cả các máy", "TatMay", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "btn btn-success" })
        </p>
        <p>@ViewBag.Loi</p>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="display table table-bordered" id="table_tbHocVien">
                <thead>
                    <th style="width:30px;">
                        TT
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.tbKichBan.TenKichBan)
                    </th>
                    <th>

                    </th>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>

                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.tbKichBan.TenKichBan)
                            </td>
                            <td>
                                @{
                                    string linkDelete = @"/tbLopHocs/KichBanDelete/?IdLopHocKichBan=" + item.IdLopHocKichBan.ToString();
                                    string linkReset = @"/tbLopHocs/CaiDatMayLe/?IdKichBan=" + item.IdKichBan.ToString()+"&IdLopHoc="+item.IdLopHoc.ToString();
                                    string linkStart = @"/tbLopHocs/BatMayLe/?IdKichBan=" + item.IdKichBan.ToString() + "&IdLopHoc=" + item.IdLopHoc.ToString();
                                    string linkStop = @"/tbLopHocs/TatMayLe/?IdKichBan=" + item.IdKichBan.ToString() + "&IdLopHoc=" + item.IdLopHoc.ToString();
                                }
                                <a href=@linkDelete title="Xóa"><span class="glyphicon glyphicon-trash"></span></a>
                                <a href=@linkReset title="Cài đặt lại máy"><span class="glyphicon glyphicon-refresh"></span></a>
                                <a href=@linkStart title="Bật máy"><span class="glyphicon glyphicon-play"></span></a>
                                <a href=@linkStop title="Tắt máy"><span class="glyphicon glyphicon-stop"></span></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            var t = $('#table_tbHocVien').DataTable({
                "pageLength": 50,
                "columnDefs": [{
                    "searchable": false,
                    "orderable": false,
                    "targets": 0
                }],
                "order": [[1, 'asc']]
            });

            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) {
                    cell.innerHTML = i + 1;
                });
            }).draw();
        })
    </script>
}