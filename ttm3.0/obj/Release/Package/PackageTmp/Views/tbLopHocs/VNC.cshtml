@model IEnumerable<ttm3._0.Models.tbHocVienLopHoc>

@{
    ViewBag.Title = "Theo dõi màn hình sinh viên";
    int Count = (int)ViewBag.Count;
    int dem = -1;
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />
<div class="card shadow mb-4">
    <div class="card-body">
        <div style="width:1090px;">
            @for (int i = 0; i < (int)ViewBag.SoLuong; i++)
            {
                <div class="row" style="margin-left:5px; margin-right:5px;">
                    @for (int j = 0; j < 3; j++)
                    {
                        dem = dem + 1;
                    <div class="col" style="border:solid 1px blue;">
                        @if (dem < Count)
                        {
                            var v = Model.FirstOrDefault(p => p.TT == dem);
                            if (v != null && v.tbComputer != null && v.AspNetUser != null)
                            {
                                <span style="width:300px;height:300px; display:inline-block;"></span>
                                <iframe src="@v.tbComputer.VncUri" class="iframe"></iframe>
                                <a href="@v.tbComputer.VncUri" target="_blank">@v.AspNetUser.Email</a>
                            }
                            else
                            {
                                <span style="width:300px;height:300px; display:inline-block;"></span>
                                <iframe src="" class="iframe"></iframe>
                                if (v != null && v.AspNetUser != null)
                                {<h6>@v.AspNetUser.Email</h6>}
                        }
                    }
                    else
                    {
                        <span style="width:300px;height:300px; display:inline-block;"></span>
                        <iframe src="" class="iframe"></iframe>
                    }
                    </div>
                    }
                </div>
            }
        </div>
    </div>
    <div class="card-footer">
        @Html.ActionLink("Quay lại", "HocVien", "tbLopHocs", new { IdLopHoc = ViewBag.IdLopHoc }, null)
    </div>
</div>
@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    <script src="~/Scripts/jquery.jeditable.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        
    </script>
}