@model ttm3._0.Models.tbLopHocKichBan

@{
    ViewBag.Title = "Thêm kịch bản vào lớp học";
}

<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
<div class="card shadow mb-4">
    <div class="card-header">
        <h3>@ViewBag.Title</h3>
    </div>
    <div class="card-body">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            @Html.HiddenFor(model => model.IdLopHocKichBan)
            @Html.HiddenFor(model => model.IdLopHoc)

            <div class="form-group">
                @Html.LabelFor(model => model.IdKichBan, htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.DropDownList("IdKichBan", null, htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.IdKichBan, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <input type="submit" value="Thêm" class="btn btn-primary" />
                </div>
            </div>
        </div>
        }
    </div>
    <div class="card-footer">
        <div>
            @Html.ActionLink("Quay lại", "Index")
        </div>
    </div>
</div>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
