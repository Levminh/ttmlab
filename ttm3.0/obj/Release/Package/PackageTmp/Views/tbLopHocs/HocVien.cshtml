@model IEnumerable<ttm3._0.Models.tbHocVienLopHoc>

@{
    ViewBag.Title = "Danh sách học viên trong lớp";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />
<div class="card shadow mb-4">
    <div class="card-header">
        <h3>@ViewBag.Title</h3>
        <div>
            <div style="display: inline-block;">
                @Html.ActionLink("Thêm học viên vào lớp học", "HocVienAdd", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "btn btn-success" })
            </div>
            <div style="display: inline-block;">
                @Html.ActionLink("Tạo mới tài khoản học viên", "Create", "clTaiKhoans", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "btn btn-success" })
            </div>
            @if (ViewBag.CoQuyen == true)
            {
            <div class="dropdown" style="display: inline-block !important;">
                <button class="btn btn-success dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    Thao tác với máy tính sinh viên
                </button>
                <div class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                    @Html.ActionLink("Khởi động tất cả máy sinh viên", "StartAll", "tbLopHocs", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "dropdown-item" })
                    @Html.ActionLink("Tắt tất cả máy sinh viên", "StopAll", "tbLopHocs", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "dropdown-item" })
                    @Html.ActionLink("VNC", "VNC", "tbLopHocs", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "dropdown-item" })
                    @Html.ActionLink("Cấp máy tự động cho sinh viên", "CapMay", "tbLopHocs", new { IdLopHoc = ViewBag.IdLopHoc }, new { @class = "dropdown-item" })
                </div>
            </div>
            }
            <div style="display: inline-block;">
                @Html.Raw("*Chú ý: Mật khẩu sau khi reset của sinh viên sẽ là: @Abc123")
            </div>
        </div>   
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="display table table-bordered" id="table_tbHocVien">
                <thead>
                    <th style="width:20px;">
                        TT
                    </th>
                    <th style="width:200px;">
                        @Html.DisplayNameFor(model => model.AspNetUser.FullName)
                    </th>
                    <th style="width:200px;">
                        Tài khoản
                    </th>
                    <th style="width:100px">
                        @Html.DisplayNameFor(model => model.TongDiem)
                    </th>
                    <th>
                        Computer
                    </th>
                    <th>
                        Status
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.GhiChu)
                    </th>
                    <th style="min-width:40px">

                    </th>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>

                            </td>
                            <td >
                                @Html.DisplayFor(modelItem => item.AspNetUser.FullName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.AspNetUser.UserName)
                            </td>
                            <td >
                                @Html.DisplayFor(modelItem => item.TongDiem)
                            </td>
                            <td class="editable-select" id="@item.IdHocVienLopHoc">
                                @Html.DisplayFor(modelItem => item.tbComputer.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.tbComputer.Status)
                            </td>
                            <td class="editable" id="@item.IdHocVienLopHoc">
                                @Html.DisplayFor(modelItem => item.GhiChu)
                            </td>
                            <td>
                                @{
                                    string linkDelete = @"/tbLopHocs/HocVienDelete/?IdHocVienLopHoc=" + item.IdHocVienLopHoc.ToString();
                                    string linkStart = @"/tbLopHocs/StartOrStop/?IdHocVienLopHoc=" + item.IdHocVienLopHoc.ToString();
                                    string linkReset = @"/tbLopHocs/ResetPassword/?IdHocVienLopHoc=" + item.IdHocVienLopHoc.ToString();

                                }
                                <a href=@linkDelete title="Xóa"><span class="glyphicon glyphicon-trash"></span></a> |
                                @if (item.tbComputer != null && ViewBag.CoQuyen==true)
                                {
                                    if (item.tbComputer.Status == "ACTIVE")
                                    {
                                        string linkVNC = item.tbComputer.VncUri;
                                        <a href=@linkStart title="Stop computer"><span class="glyphicon glyphicon-stop"></span></a>
                                        <a href=@linkVNC title="VNC" target="_blank"><span class="glyphicon glyphicon-new-window"></span></a>

                                    }
                                    else
                                    {
                                        <a href=@linkStart title="Start computer"><span class="glyphicon glyphicon-play"></span></a>
                                    }
                                }
                                <a href=@linkReset title="Đặt lại mật khẩu"><span class="glyphicon glyphicon-refresh"></span></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    <script src="~/Scripts/jquery.jeditable.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            var id = 0;
            var t = $('#table_tbHocVien').DataTable({
                "pageLength": 50,
                "columnDefs": [{
                    "searchable": false,
                    "orderable": false,
                    "targets": 0
                }],
                "order": [[1, 'asc']]
            });

            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) {
                    cell.innerHTML = i + 1;
                });
            }).draw();
            $(".editable").editable("/tbLopHocs/UpdateGhiChu", {
                type: "textarea", width: 300,submit : 'OK',
                cancel : 'Hủy',
                data: function (string) { return $.trim(string) }
            });
            $(".editable-select").editable("/tbLopHocs/UpdateComputer", {
                type: "select",
                loadurl: "/tbLopHocs/LoadComputerAsync",
                loadtype: 'GET',
                loaddata: {
                    Id: function (Id, settings) {
                        return this.Id;
                    }
                },
                submit: "OK",
                style: "inherit",
            });
            
        })
    </script>
}