@model IEnumerable<ttm3._0.Models.tbLopHoc>

@{
    ViewBag.Title = "Danh sách lớp học";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />
<div class="card shadow mb-4">
    <div class="card-header">
        <h3>@ViewBag.Title</h3>
        <p>
            @Html.ActionLink("Thêm mới lớp học", "Create", null, new { @class = "btn btn-success" })
        </p>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="display table table-bordered" id="table_tbLopHoc">
                <thead>
                <th style="width:30px;">
                        TT
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.LopHoc)
                </th>
                <th>
                    Openstack Project
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.ThongTin)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.SoSinhVien)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.SoKichBan)
                </th>
                @if (User.IsInRole("Admin"))
                {
                <th>
                    @Html.DisplayNameFor(model => model.NguoiTao)
                </th>
                }
                <th style="min-width:120px;">

                </th>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                    <tr>
                        <td></td>
                        <td>
                            @Html.DisplayFor(modelItem => item.LopHoc)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.tbProjectOpenStack.ProjectName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ThongTin)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.SoSinhVien)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.SoKichBan)
                        </td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td>
                                @Html.DisplayFor(modelItem => item.AspNetUser.Email)
                            </td>
                        }
                            <td>
                                @{
                                    string linkEdit = @"/tbLopHocs/Edit/" + item.IdLopHoc.ToString();
                                    string linkDelete = @"/tbLopHocs/Delete/" + item.IdLopHoc.ToString();
                                    string linkHocVien = @"/tbLopHocs/HocVien/?IdLopHoc=" + item.IdLopHoc.ToString();
                                    string linkKetQua = @"/tbLopHocs/KetQua/?IdLopHoc=" + item.IdLopHoc.ToString();
                                    string linkKichBan = @"/tbLopHocs/KichBan/?IdLopHoc=" + item.IdLopHoc.ToString();
                                    string linkGiamSat = @"/tbProjectOpenStacks/vnc/?IdProject=" + item.IdProjectOS.ToString();
                                }
                                <a href=@linkEdit title="Chỉnh sửa"><span class="glyphicon glyphicon-edit"></span></a> |
                                <a href=@linkDelete title="Xóa"><span class="glyphicon glyphicon-trash"></span></a> |
                                <a href=@linkHocVien title="Học viên"><span class="glyphicon glyphicon-user"></span></a> |
                                <a href=@linkKichBan title="Kịch bản"><span class="glyphicon glyphicon-star-empty"></span></a> |
                                <a href=@linkKetQua title="Kết quả"><span class="glyphicon glyphicon-check"></span></a> |
                                <a href=@linkGiamSat title="Giám sát"><span class="glyphicon glyphicon-screenshot"></span></a>
                            </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            var t = $('#table_tbLopHoc').DataTable({
                "pageLength": 50,
                "columnDefs": [{
                    "searchable": false,
                    "orderable": false,
                    "targets": 0
                }],
                "order": [[1, 'asc']]
            });

            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) {
                    cell.innerHTML = i + 1;
                });
            }).draw();
        })
    </script>
}