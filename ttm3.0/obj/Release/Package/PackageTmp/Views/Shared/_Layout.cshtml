<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <title>@ViewBag.Title - THAO TRƯỜNG MẠNG</title>
    <link href="~/Content/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="~/Content/sb-admin-2.min.css" rel="stylesheet" />
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

</head>
<body id="page-top">
    <!-- Page Wrapper -->
    <div id="wrapper">
        <!-- Sidebar -->
        <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">
            <!-- Sidebar - Brand -->
            <a class="sidebar-brand d-flex align-items-center justify-content-center" href="/SinhVien/">
                <div class="sidebar-brand-icon rotate-n-15">
                    <i class="fas fa-laugh-wink"></i>
                </div>
                <div class="sidebar-brand-text mx-3">THAO TRƯỜNG MẠNG</div>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <!-- Divider -->
                <hr class="sidebar-divider my-0">
                <li class="nav-item">
                    <a class="nav-link" href="/tbLopHocs/">
                        <i class="fas fa-fw fa-tachometer-alt"></i>
                        <span>Lớp học</span>
                    </a>
                </li>

                <!-- Divider -->
                <hr class="sidebar-divider my-0">
                <li class="nav-item">
                    <a class="nav-link" href="/tbKichBans/">
                        <i class="fas fa-fw fa-cog"></i>
                        <span>Kịch Bản</span>
                    </a>
                </li>
                <!-- Divider -->
                <hr class="sidebar-divider my-0">
                <li class="nav-item">
                    <a class="nav-link" href="/tbProjectOpenStacks/">
                        <i class="fas fa-fw fa-cog"></i>
                        <span>Phòng Lab</span>
                    </a>
                </li>
                <!-- Divider -->
                <hr class="sidebar-divider my-0">
                <li class="nav-item">
                    <a class="nav-link" href="/tbSoDoMangs/">
                        <i class="fas fa-fw fa-cog"></i>
                        <span>Sơ đồ mạng</span>
                    </a>
                </li>               

                <!-- Divider -->
                <hr class="sidebar-divider my-0">
                <!-- Nav Item - Tài khoản -->
                <li class="nav-item">
                    <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapsePages2" aria-expanded="true" aria-controls="collapsePages2">
                        <i class="fas fa-fw fa-chart-area"></i>
                        <span>Thống kê</span>
                    </a>
                    <div id="collapsePages2" class="collapse" aria-labelledby="headingPages" data-parent="#accordionSidebar">
                        <div class="bg-white py-2 collapse-inner rounded">
                            <a class="collapse-item" href="/tbKichBans/Report">Kịch bản</a>
                            <a class="collapse-item" href="/tbLopHocs/tkSinhVien">Sinh viên</a>
                            <div class="collapse-divider"></div>
                        </div>
                    </div>
                </li>

                <!-- Divider -->
                <hr class="sidebar-divider my-0">
                <!-- Nav Item - Tài khoản -->
                <li class="nav-item">
                    <a class="nav-link" href="/AspNetUsers/">
                        <i class="fas fa-fw fa-wrench"></i>
                        <span>Tài khoản</span>
                    </a>
                </li>

                
            }
            else
            {
                if (User.IsInRole("Student"))
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/SinhVien/">
                            <i class="fas fa-fw fa-wrench"></i>
                            <span>Sinh viên</span>
                        </a>
                    </li>
                }
                else
                {
                    <!-- Divider -->
                    <hr class="sidebar-divider my-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/tbLopHocs/">
                            <i class="fas fa-fw fa-tachometer-alt"></i>
                            <span>Lớp học</span>
                        </a>
                    </li>

                    <hr class="sidebar-divider my-0">
                    <li class="nav-item">
                        <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapsePages1" aria-expanded="true" aria-controls="collapsePages1">
                            <i class="fas fa-fw fa-chart-area"></i>
                            <span>Giám sát</span>
                        </a>
                        <div id="collapsePages1" class="collapse" aria-labelledby="headingPages" data-parent="#accordionSidebar">
                            <div class="bg-white py-2 collapse-inner rounded">
                                <a class="collapse-item" href="http://gs.firmware.vn/en-US/app/crc500/c500_windowsDasboard?fbclid=IwAR0LBU-oNozYinCEkvTsvRf4smxg90odwWR-qJ7rM8HxwtUcieMXHn6JZE0" target="_blank">C500_Win7L6G</a>
                                <a class="collapse-item" href="http://gs.firmware.vn/en-US/app/crc500/c500_lh_ms17010?fbclid=IwAR0LBU-oNozYinCEkvTsvRf4smxg90odwWR-qJ7rM8HxwtUcieMXHn6JZE0" target="_blank">C500_LH_MS17-010</a>
                                <a class="collapse-item" href="http://gs.firmware.vn/en-US/app/crc500/c500_lh_lohongweb?fbclid=IwAR3zNv8vffec4KeRUb23oUwF6x8HUlvT38GPw8aAdf0Sb8VJDODqhFvjSSA" target="_blank">C500_LH_LoHongWeb</a>
                                <div class="collapse-divider"></div>
                            </div>
                        </div>
                    </li>

                    <!-- Divider -->
                    <hr class="sidebar-divider my-0">
                    <!-- Nav Item - Tài khoản -->
                    <li class="nav-item">
                        <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapsePages2" aria-expanded="true" aria-controls="collapsePages2">
                            <i class="fas fa-fw fa-chart-area"></i>
                            <span>Thống kê</span>
                        </a>
                        <div id="collapsePages2" class="collapse" aria-labelledby="headingPages" data-parent="#accordionSidebar">
                            <div class="bg-white py-2 collapse-inner rounded">
                                <a class="collapse-item" href="/tbKichBans/Report">Kịch bản</a>
                                <a class="collapse-item" href="/tbLopHocs/tkSinhVien">Sinh viên</a>
                                <div class="collapse-divider"></div>
                            </div>
                        </div>
                    </li>
                }
            }
            <!-- Sidebar Toggler (Sidebar) -->
            <div class="text-center d-none d-md-inline">
                <button class="rounded-circle border-0" id="sidebarToggle"></button>
            </div>
        </ul>
        <!-- End of Sidebar -->
        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column">
            <!-- Main Content -->
            <div id="content">
                <!-- Topbar -->
                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">
                    <!-- Sidebar Toggle (Topbar) -->
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>
                    <!-- Topbar Search -->
                    <!-- Topbar Navbar -->
                    @Html.Partial("_LoginPartial")
                </nav>
                <!-- End of Topbar -->
                <!-- Begin Page Content -->
                <div class="container-fluid">
                    @RenderBody()
                </div>
                <!-- /.container-fluid -->
            </div>
            <!-- End of Main Content -->
            <!-- Footer -->
            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>Copyright &copy; BAN CHỦ NHIỆM ĐỀ TÀI 2020</span>
                    </div>
                </div>
            </footer>
            <!-- End of Footer -->
        </div>
        <!-- End of Content Wrapper -->
    </div>
    <!-- End of Page Wrapper -->
    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>
    <!-- Bootstrap core JavaScript-->
    <script src="~/Content/vendor/jquery/jquery.min.js"></script>
    <script src="~/Content/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- Core plugin JavaScript-->
    <script src="~/Content/vendor/jquery-easing/jquery.easing.min.js"></script>
    <!-- Custom scripts for all pages-->
    <script src="~/Scripts/sb-admin-2.min.js"></script>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>

</html>
