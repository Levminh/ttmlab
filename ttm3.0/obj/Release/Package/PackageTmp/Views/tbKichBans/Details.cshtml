@model ttm3._0.Models.tbKichBan

@{
    ViewBag.Title = "Chi tiết kịch bản";
}

<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
<div class="card shadow mb-4">
    <div class="card-header">
        <h3>@ViewBag.Title</h3>
    </div>
    <div class="card-body">
        <div>
            <dl class="dl-horizontal">
                <dt>
                    @Html.DisplayNameFor(model => model.MaKichBan)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.MaKichBan)
                </dd>
                <hr />

                <dt>
                    @Html.DisplayNameFor(model => model.TenKichBan)
                </dt>
                <dd>
                    @Html.DisplayFor(model => model.TenKichBan)
                </dd>
                <hr />

                <dt>
                    @Html.DisplayNameFor(model => model.IdKieuDanhGia)
                </dt>
                <dd>
                    @Html.Raw(Model.tbKieuDanhGia.KieuDanhGia)
                </dd>
                <hr />

                <dt>
                    @Html.DisplayNameFor(model => model.DapAn)
                </dt>
                <dd>
                    @Html.Raw(Model.DapAn)
                </dd>
                <hr />

                <dt>
                    @Html.DisplayNameFor(model => model.Nhoms)
                </dt>
                <dd>
                    @Html.Raw(Model.Nhoms)
                </dd>
                <hr />

                <dt>
                    @Html.DisplayNameFor(model => model.MucTieu)
                </dt>
                <dd>
                    @Html.Raw(Model.MucTieu)
                </dd>
                <hr />

                <dt>
                    @Html.DisplayNameFor(model => model.NoiDung)
                </dt>
                <dd>
                    @Html.Raw(Model.NoiDung)
                </dd>
                <hr />

                <dt>
                    @Html.DisplayNameFor(model => model.YeuCau)
                </dt>
                <dd>
                    @Html.Raw(Model.YeuCau)
                </dd>
                <hr />

                <dt>
                    @Html.DisplayNameFor(model => model.HuongDanThucHanh)
                </dt>
                <dd>
                    @Html.Raw(Model.HuongDanThucHanh)
                </dd>
            </dl>
        </div>
    </div>
    <div class="card-footer">
        <p>
            @Html.ActionLink("Chỉnh sửa", "Edit", new { id = Model.IdKichBan }) |
            @Html.ActionLink("Quay lại", "Index")
        </p>
    </div>
</div>
