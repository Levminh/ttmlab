@model IEnumerable<ttm3._0.Models.tbSoDoMangMay>

@{
    ViewBag.Title = "Danh sách máy tính trong sơ đồ mạng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-server"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">@(ViewBag.Loi != null ? ViewBag.Loi : "Quản lý máy tính trong sơ đồ mạng.")</p>
                </div>
            </div>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <a href="@Url.Action("Create", "tbSoDoMangMays", new { IdSoDoMang = ViewBag.IdSoDoMang })" class="ttm-btn ttm-btn-add">
                    <i class="fas fa-plus"></i>
                    <span>Thêm mới máy</span>
                </a>
                <a href="@Url.Action("Scan", "tbSoDoMangMays", new { IdSoDoMang = ViewBag.IdSoDoMang })" class="ttm-btn ttm-btn-secondary">
                    <i class="fas fa-search"></i>
                    <span>Scan máy trong sơ đồ mạng</span>
                </a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table display table table-bordered" id="table_project">
                    <thead>
                        <tr>
                            <th class="ttm-col-tt" style="width:40px;">TT</th>
                            <th>@Html.DisplayNameFor(model => model.MaMay)</th>
                            <th>@Html.DisplayNameFor(model => model.TenMay)</th>
                            <th>@Html.DisplayNameFor(model => model.Kieu)</th>
                            <th>@Html.DisplayNameFor(model => model.GhiChu)</th>
                            <th class="ttm-col-actions" style="min-width:80px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ttm-col-tt"></td>
                                <td class="editable-MaMay" id="@item.Id">@Html.DisplayFor(modelItem => item.MaMay)</td>
                                <td class="editable-TenMay" id="@item.Id">@Html.DisplayFor(modelItem => item.TenMay)</td>
                                <td class="editable-Kieu" id="@item.Id">@Html.DisplayFor(modelItem => item.Kieu)</td>
                                <td class="editable-GhiChu" id="@item.Id">@Html.DisplayFor(modelItem => item.GhiChu)</td>
                                <td class="ttm-col-actions">
                                    <a href="@Url.Action("Delete", "tbSoDoMangMays", new { id = item.Id })" class="ttm-act ttm-act-del" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    <script src="~/Scripts/jquery.jeditable.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            var t = $('#table_project').DataTable({
                "pageLength": 50,
                "columnDefs": [{ "searchable": false, "orderable": false, "targets": 0 }, { "orderable": false, "targets": -1 }],
                "order": [[1, 'asc']],
                "language": {
                    "search": "Tìm kiếm:",
                    "lengthMenu": "Hiển thị _MENU_ dòng",
                    "info": "Đang xem _START_–_END_ / _TOTAL_ dòng",
                    "paginate": { "first": "Đầu", "last": "Cuối", "next": "Sau", "previous": "Trước" }
                }
            });
            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) { cell.innerHTML = i + 1; });
            }).draw();
            $(".editable-MaMay").editable("/tbSoDoMangMays/UpdateMaMay", { type: "text", submit: 'OK', cancel: 'Hủy', data: function (string) { return $.trim(string); } });
            $(".editable-TenMay").editable("/tbSoDoMangMays/UpdateTenMay", { type: "text", submit: 'OK', cancel: 'Hủy', data: function (string) { return $.trim(string); } });
            $(".editable-GhiChu").editable("/tbSoDoMangMays/UpdateGhiChu", { type: "text", submit: 'OK', cancel: 'Hủy', data: function (string) { return $.trim(string); } });
            $(".editable-Kieu").editable("/tbSoDoMangMays/UpdateKieu", { type: "select", loadurl: "/tbSoDoMangMays/LoadKieuAsync", loadtype: 'GET', loaddata: null, submit: "OK", style: "inherit" });
        });
    </script>
}
