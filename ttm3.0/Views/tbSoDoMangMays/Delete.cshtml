@model ttm3._0.Models.tbSoDoMangMay

@{
    ViewBag.Title = "Xóa máy tính";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-server"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Bạn có chắc chắn muốn xóa?</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            <dl class="dl-horizontal">
                <dt>Thuộc sơ đồ mạng</dt>
                <dd>@Html.DisplayFor(model => model.tbSoDoMang.Ten)</dd>
                <dt>@Html.DisplayNameFor(model => model.MaMay)</dt>
                <dd>@Html.DisplayFor(model => model.MaMay)</dd>
                <dt>@Html.DisplayNameFor(model => model.TenMay)</dt>
                <dd>@Html.DisplayFor(model => model.TenMay)</dd>
                <dt>@Html.DisplayNameFor(model => model.GhiChu)</dt>
                <dd>@Html.DisplayFor(model => model.GhiChu)</dd>
            </dl>
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                <div class="form-actions no-color" style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
                    <button type="submit" class="ttm-btn ttm-btn-primary" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                        <i class="fas fa-trash-alt"></i>
                        <span>Xóa</span>
                    </button>
                    <a href="@Url.Action("Index", "tbSoDoMangMays", new { IdSoDoMang = Model.IdSoDoMang })" class="ttm-btn ttm-btn-secondary">
                        <i class="fas fa-arrow-left"></i>
                        <span>Quay lại</span>
                    </a>
                </div>
            }
        </div>
    </div>
</div>
