@model ttm3._0.Models.tbLichPhongLab

@{
    ViewBag.Title = "Thêm mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
<link href="~/Content/jquery.timepicker.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-calendar-plus"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">@(ViewBag.Loi != null ? ViewBag.Loi : "Đăng ký lịch sử dụng phòng lab.")</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("Index", "tbLichPhongLabs", new { IdProject = ViewBag.IdProject })" class="ttm-btn ttm-btn-secondary">
                    <i class="fas fa-arrow-left"></i>
                    <span>Quay lại</span>
                </a>
            </div>
        </div>
        <div class="ttm-body ttm-form">
            @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.HiddenFor(model => model.IdProject)
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group">
                @Html.Label("Người dùng", htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.DropDownList("IdUser", null, htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.IdUser, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.TuGio, htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.TuGio, new { htmlAttributes = new { @class = "form-control timepicker", @autocomplete = "off" } })
                    @Html.ValidationMessageFor(model => model.TuGio, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.stTuNgay, htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.stTuNgay, new { htmlAttributes = new { @class = "form-control datepicker", @autocomplete = "off" } })
                    @Html.ValidationMessageFor(model => model.stTuNgay, "", new { @class = "text-danger" })
                </div>
            </div>


            <div class="form-group">
                @Html.LabelFor(model => model.DenGio, htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.DenGio, new { htmlAttributes = new { @class = "form-control timepicker", @autocomplete = "off" } })
                    @Html.ValidationMessageFor(model => model.DenGio, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.stDenNgay, htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.stDenNgay, new { htmlAttributes = new { @class = "form-control datepicker", @autocomplete = "off" } })
                    @Html.ValidationMessageFor(model => model.stDenNgay, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <button type="submit" class="ttm-btn ttm-btn-primary">
                        <i class="fas fa-save"></i>
                        <span>Thêm mới</span>
                    </button>
                    <a href="@Url.Action("Index", "tbLichPhongLabs", new { IdProject = ViewBag.IdProject })" class="ttm-btn ttm-btn-secondary" style="margin-left: 0.5rem;">
                        <i class="fas fa-times"></i>
                        <span>Hủy</span>
                    </a>
                </div>
            </div>
        </div>
        }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Scripts/jquery-1.10.2.js"></script>
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/jquery.timepicker.min.js"></script>
    <script>
        $(document).ready(function () {
            $(".datepicker").datepicker({
                dateFormat: "dd/mm/yy"
            });
            $('input.timepicker').timepicker({
                timeFormat: 'H:mm',
                defaultTime: '7:00',
                minTime: '0:00',
                maxTime: '23:59',
                interval: 15
            });
        });
    </script>
}
