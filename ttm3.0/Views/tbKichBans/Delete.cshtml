@model ttm3._0.Models.tbKichBan

@{
    ViewBag.Title = "Xóa kịch bản";
}
<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-file-code"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Bạn có chắc chắn muốn xóa?</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            <dl class="dl-horizontal">
                <dt>@Html.DisplayNameFor(model => model.MaKichBan)</dt>
                <dd>@Html.DisplayFor(model => model.MaKichBan)</dd>
                <dt>@Html.DisplayNameFor(model => model.TenKichBan)</dt>
                <dd>@Html.DisplayFor(model => model.TenKichBan)</dd>
                <dt>@Html.DisplayNameFor(model => model.NoiDung)</dt>
                <dd>@Html.Raw(Model.NoiDung)</dd>
            </dl>
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                <div class="form-actions no-color" style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
                    <button type="submit" class="ttm-btn ttm-btn-danger">
                        <i class="fas fa-trash-alt"></i>
                        <span>Xóa</span>
                    </button>
                    <a href="@Url.Action("Index", "tbKichBans")" class="ttm-btn ttm-btn-secondary">
                        <i class="fas fa-arrow-left"></i>
                        <span>Quay lại</span>
                    </a>
                </div>
            }
        </div>
    </div>
</div>
