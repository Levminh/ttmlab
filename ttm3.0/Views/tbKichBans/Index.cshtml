@model IEnumerable<ttm3._0.Models.tbKichBan>

@{
    ViewBag.Title = "Danh sách kịch bản";
}
<link href="~/Content/datatables.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-file-code"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Quản lý kịch bản thực hành, đánh giá và liên kết sơ đồ mạng.</p>
                </div>
            </div>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <a href="@Url.Action("Create", "tbKichBans")" class="ttm-btn ttm-btn-add">
                    <i class="fas fa-plus"></i>
                    <span>Thêm mới kịch bản</span>
                </a>
                <a href="@Url.Action("Report", "tbKichBans")" class="ttm-btn ttm-btn-secondary">
                    <i class="fas fa-chart-bar"></i>
                    <span>Thống kê kết quả</span>
                </a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table display table table-bordered" id="table_tbKichBan">
                    <thead>
                        <tr>
                            <th class="ttm-col-tt" style="width:40px;">TT</th>
                            <th>@Html.DisplayNameFor(model => model.MaKichBan)</th>
                            <th>@Html.DisplayNameFor(model => model.TenKichBan)</th>
                            <th>@Html.DisplayNameFor(model => model.tbKieuDanhGia.KieuDanhGia)</th>
                            <th class="ttm-col-actions" style="min-width:120px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            string linkEdit = "/tbKichBans/Edit/" + item.IdKichBan.ToString();
                            string linkDelete = "/tbKichBans/Delete/" + item.IdKichBan.ToString();
                            string linkDetails = "/tbKichBans/Details/" + item.IdKichBan.ToString();
                            string linkSDM = "/tbKichBanSoDoMangs/Index/?IdKichBan=" + item.IdKichBan.ToString();
                            <tr>
                                <td class="ttm-col-tt"></td>
                                <td>@Html.DisplayFor(modelItem => item.MaKichBan)</td>
                                <td>@Html.DisplayFor(modelItem => item.TenKichBan)</td>
                                <td>@Html.DisplayFor(modelItem => item.tbKieuDanhGia.KieuDanhGia)</td>
                                <td class="ttm-col-actions">
                                    <div class="ttm-actions">
                                        <a href="@linkEdit" class="ttm-act" title="Chỉnh sửa"><i class="fas fa-edit"></i></a>
                                        <a href="@linkDelete" class="ttm-act ttm-act-del" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                        <a href="@linkDetails" class="ttm-act" title="Chi tiết"><i class="fas fa-info-circle"></i></a>
                                        <a href="@linkSDM" class="ttm-act" title="Sơ đồ mạng"><i class="fas fa-project-diagram"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            var t = $('#table_tbKichBan').DataTable({
                "pageLength": 50,
                "columnDefs": [{ "searchable": false, "orderable": false, "targets": 0 }, { "orderable": false, "targets": -1 }],
                "order": [[1, 'asc']],
                "language": {
                    "search": "Tìm kiếm:",
                    "lengthMenu": "Hiển thị _MENU_ dòng",
                    "info": "Đang xem _START_–_END_ / _TOTAL_ dòng",
                    "infoEmpty": "Không có dữ liệu",
                    "infoFiltered": "(lọc từ _MAX_ dòng)",
                    "zeroRecords": "Không tìm thấy kết quả",
                    "paginate": { "first": "Đầu", "last": "Cuối", "next": "Sau", "previous": "Trước" }
                }
            });
            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) {
                    cell.innerHTML = i + 1;
                });
            }).draw();
        });
    </script>
}
