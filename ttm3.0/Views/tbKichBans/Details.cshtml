@model ttm3._0.Models.tbKichBan

@{
    ViewBag.Title = "Chi tiết kịch bản";
}

<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-file-code"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">@Model.TenKichBan</p>
                </div>
            </div>
            <div class="ttm-actions">
                <a href="@Url.Action("Edit", "tbKichBans", new { id = Model.IdKichBan })" class="ttm-btn ttm-btn-primary">
                    <i class="fas fa-edit"></i>
                    <span>Chỉnh sửa</span>
                </a>
                <a href="@Url.Action("Index", "tbKichBans")" class="ttm-btn ttm-btn-secondary">
                    <i class="fas fa-arrow-left"></i>
                    <span>Quay lại</span>
                </a>
            </div>
        </div>
        <div class="ttm-body">
            <dl class="dl-horizontal">
                <dt>@Html.DisplayNameFor(model => model.MaKichBan)</dt>
                <dd>@Html.DisplayFor(model => model.MaKichBan)</dd>
                <hr />

                <dt>@Html.DisplayNameFor(model => model.TenKichBan)</dt>
                <dd>@Html.DisplayFor(model => model.TenKichBan)</dd>
                <hr />

                <dt>@Html.DisplayNameFor(model => model.IdKieuDanhGia)</dt>
                <dd>@Html.Raw(Model.tbKieuDanhGia?.KieuDanhGia)</dd>
                <hr />

                <dt>@Html.DisplayNameFor(model => model.DapAn)</dt>
                <dd>@Html.Raw(Model.DapAn)</dd>
                <hr />

                <dt>@Html.DisplayNameFor(model => model.Nhoms)</dt>
                <dd>@Html.Raw(Model.Nhoms)</dd>
                <hr />

                <dt>@Html.DisplayNameFor(model => model.MucTieu)</dt>
                <dd>@Html.Raw(Model.MucTieu)</dd>
                <hr />

                <dt>@Html.DisplayNameFor(model => model.NoiDung)</dt>
                <dd>@Html.Raw(Model.NoiDung)</dd>
                <hr />

                <dt>@Html.DisplayNameFor(model => model.YeuCau)</dt>
                <dd>@Html.Raw(Model.YeuCau)</dd>
                <hr />

                <dt>@Html.DisplayNameFor(model => model.HuongDanThucHanh)</dt>
                <dd>@Html.Raw(Model.HuongDanThucHanh)</dd>
            </dl>
        </div>
    </div>
</div>
