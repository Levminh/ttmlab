@model IEnumerable<ttm3._0.Models.tbProjectOpenStack>

@{
    ViewBag.Title = "Phòng Lab";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-flask"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Quản lý project OpenStack, phân lịch phòng lab và giám sát.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("Create", "tbProjectOpenStacks")" class="ttm-btn ttm-btn-add">
                    <i class="fas fa-plus"></i>
                    <span>Thêm mới project</span>
                </a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table display table table-bordered" id="table_project">
                    <thead>
                        <tr>
                            <th class="ttm-col-tt" style="width:40px;">TT</th>
                            <th>Project name</th>
                            <th>Project Id</th>
                            <th class="ttm-col-actions" style="min-width:200px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ttm-col-tt"></td>
                                <td>@Html.DisplayFor(modelItem => item.ProjectName)</td>
                                <td>@Html.DisplayFor(modelItem => item.ProjectId)</td>
                                <td class="ttm-col-actions">
                                    <div class="ttm-actions">
                                        <a href="@Url.Action("Edit", "tbProjectOpenStacks", new { id = item.IdProject })" class="ttm-act" title="Chỉnh sửa"><i class="fas fa-edit"></i></a>
                                        <a href="@Url.Action("Delete", "tbProjectOpenStacks", new { id = item.IdProject })" class="ttm-act ttm-act-del" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                        <a href="@Url.Action("Index", "tbLichPhongLabs", new { IdProject = item.IdProject })" class="ttm-act" title="Phân lịch"><i class="fas fa-calendar-alt"></i></a>
                                        <a href="@Url.Action("Index", "tbGiamSats", new { id = item.IdProject })" class="ttm-act" title="Link giám sát"><i class="fas fa-link"></i></a>
                                        <a href="@Url.Action("vnc", "tbProjectOpenStacks", new { IdProject = item.IdProject })" class="ttm-act" title="Giám sát"><i class="fas fa-desktop"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            var t = $('#table_project').DataTable({
                "pageLength": 50,
                "columnDefs": [{ "searchable": false, "orderable": false, "targets": 0 }, { "orderable": false, "targets": -1 }],
                "order": [[1, 'asc']],
                "language": {
                    "search": "Tìm kiếm:",
                    "lengthMenu": "Hiển thị _MENU_ dòng",
                    "info": "Đang xem _START_–_END_ / _TOTAL_ dòng",
                    "infoEmpty": "Không có dữ liệu",
                    "infoFiltered": "(lọc từ _MAX_ dòng)",
                    "zeroRecords": "Không tìm thấy kết quả",
                    "paginate": { "first": "Đầu", "last": "Cuối", "next": "Sau", "previous": "Trước" }
                }
            });
            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) {
                    cell.innerHTML = i + 1;
                });
            }).draw();
        });
    </script>
}
