@model IEnumerable<ttm3._0.Models.AspNetUser>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Tài khoản";
    string ControlName = "AspNetUsers";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-user-shield"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Quản lý tài khoản người dùng, phân quyền và bảo mật.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("Create", ControlName)" class="ttm-btn ttm-btn-add">
                    <i class="fas fa-user-plus"></i>
                    <span>Thêm mới tài khoản</span>
                </a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table display table table-bordered" id="table">
                    <thead>
                        <tr>
                            <th class="ttm-col-tt" style="width:40px;">TT</th>
                            <th>@Html.DisplayNameFor(model => model.UserName)</th>
                            <th>@Html.DisplayNameFor(model => model.FullName)</th>
                            <th>@Html.DisplayNameFor(model => model.PhoneNumber)</th>
                            <th>@Html.DisplayNameFor(model => model.LockoutEnabled)</th>
                            <th>@Html.DisplayNameFor(model => model.Roles)</th>
                            <th class="ttm-col-actions" style="min-width:120px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            string linkEdit = "/" + ControlName + "/Edit/" + item.Id;
                            string linkDetails = "/" + ControlName + "/Details/" + item.Id;
                            string linkDelete = "/" + ControlName + "/Delete/" + item.Id;
                            string linkPQ = "/AspNetUserRoles/Index/?id=" + item.Id;
                            <tr>
                                <td class="ttm-col-tt"></td>
                                <td>@Html.DisplayFor(modelItem => item.UserName)</td>
                                <td>@Html.DisplayFor(modelItem => item.FullName)</td>
                                <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                                <td>@Html.DisplayFor(modelItem => item.LockoutEnabled)</td>
                                <td>@Html.DisplayFor(modelItem => item.Roles)</td>
                                <td class="ttm-col-actions">
                                    <div class="ttm-actions">
                                        <a href="@linkEdit" class="ttm-act" title="Chỉnh sửa"><i class="fas fa-edit"></i></a>
                                        <a href="@linkDetails" class="ttm-act" title="Chi tiết"><i class="fas fa-list"></i></a>
                                        <a href="@linkDelete" class="ttm-act ttm-act-del" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                        <a href="@linkPQ" class="ttm-act" title="Phân quyền"><i class="fas fa-user-cog"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            var t = $('#table').DataTable({
                "pageLength": 50,
                "columnDefs": [{ "searchable": false, "orderable": false, "targets": 0 }, { "orderable": false, "targets": -1 }],
                "order": [[1, 'asc']],
                "language": {
                    "search": "Tìm kiếm:",
                    "lengthMenu": "Hiển thị _MENU_ dòng",
                    "info": "Đang xem _START_–_END_ / _TOTAL_ dòng",
                    "infoEmpty": "Không có dữ liệu",
                    "infoFiltered": "(lọc từ _MAX_ dòng)",
                    "zeroRecords": "Không tìm thấy kết quả",
                    "paginate": { "first": "Đầu", "last": "Cuối", "next": "Sau", "previous": "Trước" }
                }
            });
            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) {
                    cell.innerHTML = i + 1;
                });
            }).draw();
        });
    </script>
}
