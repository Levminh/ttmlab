@model ttm3._0.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "Đổi mật khẩu";
}

<style>
    .change-pw-page { padding: 1.5rem 0 3rem; }
    .change-pw-wrapper { max-width: 480px; margin: 0 auto; }
    .change-pw-card {
        background: var(--primary-white, #fff);
        border-radius: 16px;
        box-shadow: var(--shadow-soft, 0 2px 10px rgba(0,0,0,.08));
        border: 1px solid var(--sidebar-border, #e5e7eb);
        overflow: hidden;
        animation: changePwFadeIn 0.4s ease;
    }
    @@keyframes changePwFadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .change-pw-header {
        padding: 1.5rem 1.75rem;
        background: linear-gradient(135deg, rgba(0, 168, 255, 0.08) 0%, rgba(0, 102, 255, 0.06) 100%);
        border-bottom: 1px solid var(--sidebar-border, #e5e7eb);
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .change-pw-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--accent-cyan, #00a8ff), var(--primary-blue, #0066ff));
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 1.25rem;
        box-shadow: 0 4px 12px rgba(0, 168, 255, 0.35);
    }
    .change-pw-title { font-size: 1.25rem; font-weight: 700; color: var(--text-primary, #1a1a1a); margin: 0; }
    .change-pw-subtitle { font-size: 0.875rem; color: var(--text-light, #6b7280); margin: 0.25rem 0 0; }
    .change-pw-body { padding: 1.75rem 1.75rem 2rem; }
    .change-pw-form .form-group { margin-bottom: 1.25rem; }
    .change-pw-form label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-secondary, #4a5568);
        margin-bottom: 0.4rem;
    }
    .change-pw-form .input-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }
    .change-pw-form .input-wrap i {
        position: absolute;
        left: 14px;
        color: var(--text-light, #6b7280);
        font-size: 0.95rem;
        pointer-events: none;
    }
    .change-pw-form input[type="password"] {
        width: 100%;
        padding: 12px 14px 12px 42px;
        font-size: 0.95rem;
        border: 1px solid var(--sidebar-border, #e5e7eb);
        border-radius: 10px;
        background: var(--primary-light, #f8f9fa);
        color: var(--text-primary, #1a1a1a);
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .change-pw-form input[type="password"]::placeholder { color: var(--text-light, #6b7280); }
    .change-pw-form input[type="password"]:focus {
        outline: none;
        border-color: var(--accent-cyan, #00a8ff);
        box-shadow: 0 0 0 3px rgba(0, 168, 255, 0.15);
        background: var(--primary-white, #fff);
    }
    .change-pw-form .validation-summary-errors {
        margin-bottom: 1rem;
        padding: 12px 14px;
        border-radius: 10px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
        font-size: 0.875rem;
    }
    .change-pw-form .validation-summary-errors ul { margin: 0; padding-left: 1.25rem; }
    .change-pw-form .field-validation-error { font-size: 0.8rem; color: #b91c1c; margin-top: 0.25rem; display: block; }
    .change-pw-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--sidebar-border, #e5e7eb);
    }
    .change-pw-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 12px 24px;
        font-size: 0.95rem;
        font-weight: 600;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .change-pw-btn-primary {
        background: linear-gradient(135deg, var(--accent-cyan, #00a8ff), var(--primary-blue, #0066ff));
        color: #fff;
        box-shadow: 0 4px 12px rgba(0, 168, 255, 0.35);
    }
    .change-pw-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(0, 168, 255, 0.4);
    }
    .change-pw-btn-secondary {
        background: var(--primary-light, #f8f9fa);
        color: var(--text-secondary, #4a5568);
        text-decoration: none;
        border: 1px solid var(--sidebar-border, #e5e7eb);
    }
    .change-pw-btn-secondary:hover { background: #eef1f4; color: var(--primary-blue, #0066ff); }
    .change-pw-hint {
        font-size: 0.8rem;
        color: var(--text-light, #6b7280);
        margin-top: 0.35rem;
    }
</style>

<div class="change-pw-page">
    <div class="change-pw-wrapper">
        <div class="change-pw-card">
            <div class="change-pw-header">
                <div class="change-pw-icon"><i class="fas fa-key"></i></div>
                <div>
                    <h1 class="change-pw-title">@ViewBag.Title</h1>
                    <p class="change-pw-subtitle">Cập nhật mật khẩu đăng nhập của bạn. Nên dùng mật khẩu mạnh, ít nhất 6 ký tự.</p>
                </div>
            </div>
            <div class="change-pw-body">
                @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { @class = "change-pw-form", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                    <div class="form-group">
                        @Html.LabelFor(m => m.OldPassword)
                        <div class="input-wrap">
                            <i class="fas fa-lock"></i>
                            @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", placeholder = "Nhập mật khẩu hiện tại" })
                        </div>
                        @Html.ValidationMessageFor(m => m.OldPassword)
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.NewPassword)
                        <div class="input-wrap">
                            <i class="fas fa-lock-open"></i>
                            @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control", placeholder = "Ít nhất 6 ký tự" })
                        </div>
                        <span class="change-pw-hint">Mật khẩu mới tối thiểu 6 ký tự.</span>
                        @Html.ValidationMessageFor(m => m.NewPassword)
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.ConfirmPassword)
                        <div class="input-wrap">
                            <i class="fas fa-check-double"></i>
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Nhập lại mật khẩu mới" })
                        </div>
                        @Html.ValidationMessageFor(m => m.ConfirmPassword)
                    </div>

                    <div class="change-pw-actions">
                        <button type="submit" class="change-pw-btn change-pw-btn-primary">
                            <i class="fas fa-save"></i>
                            <span>Đổi mật khẩu</span>
                        </button>
                        <a href="@Url.Action("Index", "Manage")" class="change-pw-btn change-pw-btn-secondary">
                            <i class="fas fa-arrow-left"></i>
                            <span>Quay lại</span>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
