@model ttm3._0.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "Đổi mật khẩu";
}

<div class="ttm-page">
    <div class="ttm-form-wrapper">
        <div class="ttm-card">
            <div class="ttm-header">
                <div class="ttm-header-left">
                    <div class="ttm-icon"><i class="fas fa-key"></i></div>
                    <div>
                        <h1 class="ttm-title">@ViewBag.Title</h1>
                        <p class="ttm-subtitle">Cập nhật mật khẩu đăng nhập. Nên dùng mật khẩu mạnh, ít nhất 6 ký tự.</p>
                    </div>
                </div>
            </div>
            <div class="ttm-body">
                @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { @class = "ttm-form", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                    <div class="form-group">
                        @Html.LabelFor(m => m.OldPassword)
                        <div class="input-wrap">
                            <i class="fas fa-lock"></i>
                            @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", placeholder = "Nhập mật khẩu hiện tại" })
                        </div>
                        @Html.ValidationMessageFor(m => m.OldPassword)
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.NewPassword)
                        <div class="input-wrap">
                            <i class="fas fa-lock-open"></i>
                            @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control", placeholder = "Ít nhất 6 ký tự" })
                        </div>
                        <span class="ttm-hint">Mật khẩu mới tối thiểu 6 ký tự.</span>
                        @Html.ValidationMessageFor(m => m.NewPassword)
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.ConfirmPassword)
                        <div class="input-wrap">
                            <i class="fas fa-check-double"></i>
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Nhập lại mật khẩu mới" })
                        </div>
                        @Html.ValidationMessageFor(m => m.ConfirmPassword)
                    </div>

                    <div class="ttm-form-actions">
                        <button type="submit" class="ttm-btn ttm-btn-add">
                            <i class="fas fa-save"></i>
                            <span>Đổi mật khẩu</span>
                        </button>
                        <a href="@Url.Action("Index", "Manage")" class="ttm-btn ttm-btn-secondary">
                            <i class="fas fa-arrow-left"></i>
                            <span>Quay lại</span>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
