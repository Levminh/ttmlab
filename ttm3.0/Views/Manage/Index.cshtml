@model ttm3._0.Models.IndexViewModel
@{
    ViewBag.Title = "Cài đặt tài khoản";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-user-cog"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Quản lý mật khẩu và đăng nhập bên ngoài.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @if (!string.IsNullOrEmpty(ViewBag.StatusMessage as string))
            {
                <p class="ttm-status-msg">@ViewBag.StatusMessage</p>
            }

            <div class="ttm-settings-list">
                <div class="ttm-settings-item">
                    <div class="ttm-settings-label">
                        <i class="fas fa-key"></i>
                        <span>Mật khẩu</span>
                    </div>
                    <div class="ttm-settings-value">
                        @if (Model.HasPassword)
                        {
                            @Html.ActionLink("Đổi mật khẩu", "ChangePassword", null, new { @class = "ttm-btn ttm-btn-primary" })
                        }
                        else
                        {
                            @Html.ActionLink("Tạo mật khẩu", "SetPassword", null, new { @class = "ttm-btn ttm-btn-primary" })
                        }
                    </div>
                </div>

                <div class="ttm-settings-item">
                    <div class="ttm-settings-label">
                        <i class="fas fa-link"></i>
                        <span>Đăng nhập bên ngoài</span>
                    </div>
                    <div class="ttm-settings-value">
                        <span class="ttm-settings-count">@Model.Logins.Count</span>
                        @Html.ActionLink("Quản lý", "ManageLogins", null, new { @class = "ttm-btn ttm-btn-secondary" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .ttm-status-msg {
        padding: 10px 14px;
        border-radius: 8px;
        background: rgba(74, 222, 128, 0.12);
        border: 1px solid rgba(74, 222, 128, 0.3);
        color: #86efac;
        font-size: 0.9rem;
        margin-bottom: 1.25rem;
    }
    .ttm-settings-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }
    .ttm-settings-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        padding: 14px 0;
        border-bottom: 1px solid rgba(56, 189, 248, 0.15);
    }
    .ttm-settings-item:last-child {
        border-bottom: none;
    }
    .ttm-settings-label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        font-size: 0.9rem;
    }
    .ttm-settings-label i {
        color: var(--cyan);
        font-size: 1rem;
    }
    .ttm-settings-value {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .ttm-settings-count {
        font-size: 0.85rem;
        color: var(--text-dim);
    }
</style>
