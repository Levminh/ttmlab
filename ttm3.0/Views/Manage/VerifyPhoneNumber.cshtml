@model ttm3._0.Models.VerifyPhoneNumberViewModel
@{
    ViewBag.Title = "Xác thực số điện thoại";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-sms"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Nhập mã xác thực đã gửi đến số của bạn.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm("VerifyPhoneNumber", "Manage", FormMethod.Post, new { @class = "ttm-form", role = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("phoneNumber", Model.PhoneNumber)
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                @if (!string.IsNullOrEmpty(ViewBag.Status as string))
                {
                    <p class="ttm-status-msg">@ViewBag.Status</p>
                }

                <div class="form-group">
                    @Html.LabelFor(m => m.Code)
                    @Html.TextBoxFor(m => m.Code, new { @class = "form-control", placeholder = "Mã xác thực" })
                    @Html.ValidationMessageFor(m => m.Code)
                </div>

                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-primary">
                        <i class="fas fa-check"></i>
                        <span>Xác thực</span>
                    </button>
                    <a href="@Url.Action("Index", "Manage")" class="ttm-btn ttm-btn-secondary">
                        <i class="fas fa-arrow-left"></i>
                        <span>Quay lại</span>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .ttm-status-msg { padding: 10px 14px; border-radius: 8px; background: rgba(74, 222, 128, 0.12); border: 1px solid rgba(74, 222, 128, 0.3); color: #86efac; font-size: 0.9rem; margin-bottom: 1rem; }
</style>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
