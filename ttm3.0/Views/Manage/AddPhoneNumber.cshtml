@model ttm3._0.Models.AddPhoneNumberViewModel
@{
    ViewBag.Title = "Thêm số điện thoại";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-phone"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Thêm số điện thoại để bảo mật hai yếu tố.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm("AddPhoneNumber", "Manage", FormMethod.Post, new { @class = "ttm-form", role = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                <div class="form-group">
                    @Html.LabelFor(m => m.Number)
                    @Html.TextBoxFor(m => m.Number, new { @class = "form-control", placeholder = "Số điện thoại" })
                    @Html.ValidationMessageFor(m => m.Number)
                </div>

                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-primary">
                        <i class="fas fa-paper-plane"></i>
                        <span>Gửi mã</span>
                    </button>
                    <a href="@Url.Action("Index", "Manage")" class="ttm-btn ttm-btn-secondary">
                        <i class="fas fa-arrow-left"></i>
                        <span>Quay lại</span>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
