@model ttm3._0.Models.FileModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-upload"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Tải lên file kết quả thực hành.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm("UploadFiles", "tbKetQuas", FormMethod.Post, new { enctype = "multipart/form-data", @class = "ttm-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })
                @Html.HiddenFor(model => model.Id)

                <div class="form-group">
                    @Html.LabelFor(model => model.files)
                    @Html.TextBoxFor(model => model.files, "", new { @type = "file", @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.files)
                </div>

                @if (!string.IsNullOrEmpty(ViewBag.UploadStatus as string))
                {
                    <p class="ttm-status-msg">@Html.Raw(ViewBag.UploadStatus)</p>
                }

                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-primary">
                        <i class="fas fa-upload"></i>
                        <span>Tải lên</span>
                    </button>
                </div>
            }
        </div>
    </div>
</div>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}