@model ttm3._0.Models.tbKetQua
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-flag-checkered"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Nộp đáp án kịch bản CTF.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "ttm-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })
                @Html.HiddenFor(model => model.IdKetQua)
                @Html.HiddenFor(model => model.IdKichBan)
                @Html.HiddenFor(model => model.IdLopHoc)
                @Html.HiddenFor(model => model.IdHocVien)

                <div class="form-group">
                    @Html.LabelFor(model => model.DapAn)
                    @Html.EditorFor(model => model.DapAn, new { htmlAttributes = new { @class = "form-control", placeholder = "Nhập đáp án" } })
                    @Html.ValidationMessageFor(model => model.DapAn)
                </div>

                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-primary">
                        <i class="fas fa-paper-plane"></i>
                        <span>Nộp bài</span>
                    </button>
                </div>
            }
        </div>
    </div>
</div>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
