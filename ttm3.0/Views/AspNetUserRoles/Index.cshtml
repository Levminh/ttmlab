@model IEnumerable<ttm3._0.Models.AspNetUserRole>

@{
    ViewBag.Title = "Quyền hạn";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string ControlName = "AspNetUserRoles";
}
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h2>Danh sách quyền hạn</h2>
        <p>
            @Html.ActionLink("Thêm quyền hạn", "Create", new { id = ViewBag.Id }, new { @calss = "btn btn-primary" })
        </p>
    </div>
    <div class="card-body">
        <div class="table-responsive table-myindex">
            <table class="table table-bordered">
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.AspNetRole.Name)
                    </th>
                    <th></th>
                </tr>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.AspNetRole.Name)
                        </td>
                        <td>
                            @{
                                string linkDelete = @"/" + ControlName + @"/Delete/?id=" + item.UserId + "&role=" + item.RoleId;
                            }
                            <a href=@linkDelete title="Xóa"><span class="glyphicon glyphicon-trash"></span></a>
                        </td>
                    </tr>
                                }

            </table>
        </div>
        <div>
            @Html.ActionLink("Quay lại danh sách tài khoản", "Index", "AspNetUsers", null, new { @class = "btn btn-primary" })
        </div>
    </div>
</div>
