@model IEnumerable<ttm3._0.Models.AspNetUserRole>

@{
    ViewBag.Title = "Quyền hạn";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string ControlName = "AspNetUserRoles";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-user-cog"></i></div>
                <div>
                    <h1 class="ttm-title">Danh sách quyền hạn</h1>
                    <p class="ttm-subtitle">Phân quyền cho tài khoản người dùng.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("Create", "AspNetUserRoles", new { id = ViewBag.Id })" class="ttm-btn ttm-btn-add">
                    <i class="fas fa-plus"></i>
                    <span>Thêm quyền hạn</span>
                </a>
                <a href="@Url.Action("Index", "AspNetUsers")" class="ttm-btn ttm-btn-secondary">
                    <i class="fas fa-arrow-left"></i>
                    <span>Quay lại tài khoản</span>
                </a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table table table-bordered">
                    <thead>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.AspNetRole.Name)</th>
                            <th class="ttm-col-actions" style="min-width:80px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var linkDelete = "/" + ControlName + "/Delete/?id=" + item.UserId + "&role=" + item.RoleId;
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.AspNetRole.Name)</td>
                                <td class="ttm-col-actions">
                                    <a href="@linkDelete" class="ttm-act ttm-act-del" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
