@model ttm3._0.Models.AspNetUserRole

@{
    ViewBag.Title = "Xóa quyền hạn";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string ControlName = "AspNetUserRole";
}
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h3>Xóa quyền hạn</h3>
        <h4>Bạn có chắc muốn xóa quyền hạn nàys?</h4>
    </div>
    <div class="card-body">
        <div>
            <dl class="dl-horizontal">
                <dt>
                    @Html.DisplayNameFor(model => model.AspNetRole.Name)
                </dt>

                <dd>
                    @Html.DisplayFor(model => model.AspNetRole.Name)
                </dd>

            </dl>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="form-actions no-color">
                    <input type="submit" value="Xóa" class="btn btn-primary" /> |
                    @Html.ActionLink("Quay lại danh sách quyền hạn", "Index", @ControlName, null, new { @class = "btn btn-primary" })
                </div>
            }
        </div>
    </div>
</div>
