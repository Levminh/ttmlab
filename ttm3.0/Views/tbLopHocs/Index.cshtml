@model IEnumerable<ttm3._0.Models.tbLopHoc>

@{
    ViewBag.Title = "Danh sách lớp học";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-chalkboard-teacher"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Quản lý lớp học, học viên, kịch bản và kết quả thực hành.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("Create", "tbLopHocs")" class="ttm-btn ttm-btn-add">
                    <i class="fas fa-plus"></i>
                    <span>Thêm mới lớp học</span>
                </a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table display table table-bordered" id="table_tbLopHoc">
                    <thead>
                        <tr>
                            <th class="ttm-col-tt" style="width:36px;">TT</th>
                            <th>@Html.DisplayNameFor(model => model.LopHoc)</th>
                            <th>Openstack Project</th>
                            <th>@Html.DisplayNameFor(model => model.ThongTin)</th>
                            <th>@Html.DisplayNameFor(model => model.SoSinhVien)</th>
                            <th>@Html.DisplayNameFor(model => model.SoKichBan)</th>
                            @if (User.IsInRole("Admin"))
                            {
                                <th>@Html.DisplayNameFor(model => model.NguoiTao)</th>
                            }
                            <th class="ttm-col-actions" style="min-width:130px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var linkEdit = Url.Action("Edit", "tbLopHocs", new { id = item.IdLopHoc });
                            var linkDelete = Url.Action("Delete", "tbLopHocs", new { id = item.IdLopHoc });
                            var linkHocVien = Url.Action("HocVien", "tbLopHocs", new { IdLopHoc = item.IdLopHoc });
                            var linkKetQua = Url.Action("KetQua", "tbLopHocs", new { IdLopHoc = item.IdLopHoc });
                            var linkKichBan = Url.Action("KichBan", "tbLopHocs", new { IdLopHoc = item.IdLopHoc });
                            var linkGiamSat = Url.Action("vnc", "tbProjectOpenStacks", new { IdProject = item.IdProjectOS });
                            <tr>
                                <td class="ttm-col-tt"></td>
                                <td>@Html.DisplayFor(modelItem => item.LopHoc)</td>
                                <td>@(item.tbProjectOpenStack?.ProjectName)</td>
                                <td>@Html.DisplayFor(modelItem => item.ThongTin)</td>
                                <td>@Html.DisplayFor(modelItem => item.SoSinhVien)</td>
                                <td>@Html.DisplayFor(modelItem => item.SoKichBan)</td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td>@(item.AspNetUser?.Email)</td>
                                }
                                <td class="ttm-col-actions">
                                    <div class="ttm-actions">
                                        <a href="@linkEdit" class="ttm-act" title="Chỉnh sửa"><i class="fas fa-edit"></i></a>
                                        <a href="@linkDelete" class="ttm-act ttm-act-del" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                        <a href="@linkHocVien" class="ttm-act" title="Học viên"><i class="fas fa-users"></i></a>
                                        <a href="@linkKichBan" class="ttm-act" title="Kịch bản"><i class="fas fa-list-alt"></i></a>
                                        <a href="@linkKetQua" class="ttm-act" title="Kết quả"><i class="fas fa-chart-bar"></i></a>
                                        <a href="@linkGiamSat" class="ttm-act" title="Giám sát"><i class="fas fa-desktop"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(function () {
            var t = $('#table_tbLopHoc').DataTable({
                pageLength: 50,
                columnDefs: [
                    { searchable: false, orderable: false, targets: 0 },
                    { orderable: false, targets: -1 }
                ],
                order: [[1, 'asc']],
                language: {
                    search: 'Tìm kiếm:',
                    lengthMenu: 'Hiển thị _MENU_ dòng',
                    info: 'Đang xem _START_–_END_ / _TOTAL_ dòng',
                    infoEmpty: 'Không có dữ liệu',
                    infoFiltered: '(lọc từ _MAX_ dòng)',
                    zeroRecords: 'Không tìm thấy kết quả',
                    paginate: {
                        first: 'Đầu',
                        last: 'Cuối',
                        next: 'Sau',
                        previous: 'Trước'
                    }
                }
            });
            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) {
                    cell.innerHTML = i + 1;
                });
            }).draw();
        });
    </script>
}
