@model ttm3._0.Models.tbHocVienLopHoc

@{
    ViewBag.Title = "Thêm học viên vào lớp học";
    var idLop = Model?.IdLopHoc ?? (int?)ViewBag.IdLopHoc;
}

<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-user-plus"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Chọn tài khoản học viên để thêm vào lớp.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "ttm-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })
                @Html.HiddenFor(model => model.IdHocVienLopHoc)
                @Html.HiddenFor(model => model.IdLopHoc)

                <div class="form-group">
                    @Html.LabelFor(model => model.IdHocVien)
                    @Html.DropDownList("IdHocVien", null, htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.IdHocVien, "", new { @class = "field-validation-error" })
                </div>
                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-add"><i class="fas fa-plus"></i> Thêm</button>
                    <a href="@Url.Action("HocVien", "tbLopHocs", new { IdLopHoc = idLop })" class="ttm-btn ttm-btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
