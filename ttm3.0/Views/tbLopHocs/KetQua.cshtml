@model IEnumerable<ttm3._0.Models.clKetQua>

@{
    ViewBag.Title = "Kết quả học viên";
    var idLop = ViewBag.IdLopHoc as int?;
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-chart-bar"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Xem và chỉnh sửa điểm theo kịch bản. Click vào ô điểm để sửa.</p>
                </div>
            </div>
            <div>
                @if (idLop.HasValue)
                {
                    <a href="@Url.Action("HocVien", "tbLopHocs", new { IdLopHoc = idLop })" class="ttm-btn ttm-btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                }
            </div>
        </div>
        <div class="ttm-body">
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table display table table-bordered" id="table_tbHocVien">
                    <thead>
                        <tr>
                            <th class="ttm-col-tt">TT</th>
                            <th>Sinh viên</th>
                            @foreach (var kb in ViewBag.LstKB)
                            {
                                <th>@kb.tbKichBan.MaKichBan</th>
                                <th>Submit</th>
                            }
                            <th>Tổng điểm</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ttm-col-tt"></td>
                                <td>@(item.User?.UserName)</td>
                                @foreach (var kq in item.lsKQ)
                                {
                                    <td class="editable" id="@kq.IdKetQua">@kq.Diem</td>
                                    <td>
                                        @if (kq.KieuDanhGia == 1)
                                        {
                                            @Html.Raw(kq.DapAn)
                                        }
                                        else
                                        {
                                            <a href="@kq.UrlFileDapAn" class="ttm-link" target="_blank">File đáp án</a>
                                        }
                                    </td>
                                }
                                <td>@item.TongDiem</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    <script src="~/Scripts/jquery.jeditable.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(function () {
            var t = $('#table_tbHocVien').DataTable({
                pageLength: 50,
                columnDefs: [{ searchable: false, orderable: false, targets: 0 }],
                order: [[1, 'asc']],
                language: { search: 'Tìm kiếm:', lengthMenu: 'Hiển thị _MENU_ dòng', info: 'Đang xem _START_–_END_ / _TOTAL_ dòng', infoEmpty: 'Không có dữ liệu', infoFiltered: '(lọc từ _MAX_ dòng)', zeroRecords: 'Không tìm thấy kết quả', paginate: { first: 'Đầu', last: 'Cuối', next: 'Sau', previous: 'Trước' } }
            });
            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) { cell.innerHTML = i + 1; });
            }).draw();
            $(".editable").editable("/tbLopHocs/UpdateKetQua", { type: "number", width: 90, maxlength: 20, data: function (s) { return $.trim(s); } });
        });
    </script>
}
