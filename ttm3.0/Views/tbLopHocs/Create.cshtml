@model ttm3._0.Models.tbLopHoc

@{
    ViewBag.Title = "Thêm mới lớp học";
}

<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />
<link href="~/Content/lophoc.css" rel="stylesheet" />

<div class="lh-page">
    <div class="lh-card">
        <div class="lh-header">
            <div class="lh-header-left">
                <div class="lh-icon"><i class="fas fa-plus-circle"></i></div>
                <div>
                    <h1 class="lh-title">@ViewBag.Title</h1>
                    <p class="lh-subtitle">Tạo lớp học mới và gán phòng Lab OpenStack.</p>
                </div>
            </div>
        </div>
        <div class="lh-body">
            @using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "lh-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                <div class="form-group">
                    @Html.LabelFor(model => model.LopHoc)
                    @Html.EditorFor(model => model.LopHoc, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.LopHoc, "", new { @class = "field-validation-error" })
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.ThongTin)
                    @Html.EditorFor(model => model.ThongTin, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ThongTin, "", new { @class = "field-validation-error" })
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.IdProjectOS)
                    @Html.DropDownList("IdProjectOS", null, htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.IdProjectOS, "", new { @class = "field-validation-error" })
                </div>
                <div class="lh-actions">
                    <button type="submit" class="lh-btn lh-btn-primary"><i class="fas fa-save"></i> Thêm</button>
                    <a href="@Url.Action("Index")" class="lh-btn lh-btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
