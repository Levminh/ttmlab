@model ttm3._0.Models.tbLopHoc

@{
    ViewBag.Title = "Thêm mới lớp học";
}

<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-plus-circle"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Tạo lớp học mới và gán phòng Lab OpenStack.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "ttm-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                <div class="form-group">
                    @Html.LabelFor(model => model.LopHoc)
                    @Html.EditorFor(model => model.LopHoc, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.LopHoc, "", new { @class = "field-validation-error" })
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.ThongTin)
                    @Html.EditorFor(model => model.ThongTin, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ThongTin, "", new { @class = "field-validation-error" })
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.IdProjectOS)
                    @Html.DropDownList("IdProjectOS", null, htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.IdProjectOS, "", new { @class = "field-validation-error" })
                </div>
                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-add"><i class="fas fa-save"></i> Thêm</button>
                    <a href="@Url.Action("Index")" class="ttm-btn ttm-btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
