@model IEnumerable<ttm3._0.Models.tbLopHocKichBan>

@{
    ViewBag.Title = "Danh sách kịch bản trong lớp";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-list-alt"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Quản lý kịch bản thực hành và điều khiển máy theo kịch bản.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("HocVien", new { IdLopHoc = ViewBag.IdLopHoc })" class="ttm-btn ttm-btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="ttm-toolbar">
                <a href="@Url.Action("KichBanAdd", new { IdLopHoc = ViewBag.IdLopHoc })" class="ttm-btn ttm-btn-add"><i class="fas fa-plus"></i> Thêm kịch bản</a>
                <a href="@Url.Action("CaiDatMay", new { IdLopHoc = ViewBag.IdLopHoc })" class="ttm-btn ttm-btn-secondary"><i class="fas fa-sync-alt"></i> Cài đặt lại tất cả máy</a>
                <a href="@Url.Action("BatMay", new { IdLopHoc = ViewBag.IdLopHoc })" class="ttm-btn ttm-btn-secondary"><i class="fas fa-play"></i> Bật tất cả máy</a>
                <a href="@Url.Action("TatMay", new { IdLopHoc = ViewBag.IdLopHoc })" class="ttm-btn ttm-btn-secondary"><i class="fas fa-stop"></i> Tắt tất cả máy</a>
            </div>
            @if (ViewBag.Loi != null)
            {
                <div class="ttm-err">@ViewBag.Loi</div>
            }
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table display table table-bordered" id="table_tbHocVien">
                    <thead>
                        <tr>
                            <th class="ttm-col-tt" style="width:36px;">TT</th>
                            <th>@Html.DisplayNameFor(model => model.tbKichBan.TenKichBan)</th>
                            <th class="ttm-col-actions" style="min-width:140px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var linkDelete = Url.Action("KichBanDelete", "tbLopHocs", new { IdLopHocKichBan = item.IdLopHocKichBan });
                            var linkReset = Url.Action("CaiDatMayLe", "tbLopHocs", new { IdKichBan = item.IdKichBan, IdLopHoc = item.IdLopHoc });
                            var linkStart = Url.Action("BatMayLe", "tbLopHocs", new { IdKichBan = item.IdKichBan, IdLopHoc = item.IdLopHoc });
                            var linkStop = Url.Action("TatMayLe", "tbLopHocs", new { IdKichBan = item.IdKichBan, IdLopHoc = item.IdLopHoc });
                            <tr>
                                <td class="ttm-col-tt"></td>
                                <td>@Html.DisplayFor(m => item.tbKichBan.TenKichBan)</td>
                                <td class="ttm-col-actions">
                                    <div class="ttm-actions">
                                        <a href="@linkDelete" class="ttm-act ttm-act-del" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                        <a href="@linkReset" class="ttm-act" title="Cài đặt lại máy"><i class="fas fa-sync-alt"></i></a>
                                        <a href="@linkStart" class="ttm-act" title="Bật máy"><i class="fas fa-play"></i></a>
                                        <a href="@linkStop" class="ttm-act" title="Tắt máy"><i class="fas fa-stop"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(function () {
            var t = $('#table_tbHocVien').DataTable({
                pageLength: 50,
                columnDefs: [{ searchable: false, orderable: false, targets: 0 }, { orderable: false, targets: -1 }],
                order: [[1, 'asc']],
                language: { search: 'Tìm kiếm:', lengthMenu: 'Hiển thị _MENU_ dòng', info: 'Đang xem _START_–_END_ / _TOTAL_ dòng', infoEmpty: 'Không có dữ liệu', infoFiltered: '(lọc từ _MAX_ dòng)', zeroRecords: 'Không tìm thấy kết quả', paginate: { first: 'Đầu', last: 'Cuối', next: 'Sau', previous: 'Trước' } }
            });
            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) { cell.innerHTML = i + 1; });
            }).draw();
        });
    </script>
}
