@model ttm3._0.Models.tbLopHoc

@{
    ViewBag.Title = "Xóa lớp học";
}

<link href="~/Content/themes/base/jquery-ui.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon" style="background: linear-gradient(135deg, #ef4444, #dc2626);"><i class="fas fa-trash-alt"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Bạn có chắc chắn muốn xóa lớp học này? Thao tác không thể hoàn tác.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            <dl class="ttm-dl">
                <dt>@Html.DisplayNameFor(model => model.LopHoc)</dt>
                <dd>@Html.DisplayFor(model => model.LopHoc)</dd>
                <dt>@Html.DisplayNameFor(model => model.ThongTin)</dt>
                <dd>@Html.DisplayFor(model => model.ThongTin)</dd>
            </dl>
            @using (Html.BeginForm("Delete", "tbLopHocs", FormMethod.Post, new { @class = "ttm-form" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.IdLopHoc" />
                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-danger"><i class="fas fa-trash-alt"></i> Xóa</button>
                    <a href="@Url.Action("Index")" class="ttm-btn ttm-btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                </div>
            }
        </div>
    </div>
</div>
