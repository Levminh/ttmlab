@model IEnumerable<ttm3._0.Models.tbHocVienLopHoc>

@{
    ViewBag.Title = "Theo dõi màn hình sinh viên";
    int count = (int)ViewBag.Count;
    int soLuong = (int)ViewBag.SoLuong;
    int idx = -1;
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-desktop"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Xem màn hình VNC của từng máy sinh viên. Click vào link để mở cửa sổ riêng.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("HocVien", "tbLopHocs", new { IdLopHoc = ViewBag.IdLopHoc })" class="ttm-btn ttm-btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="ttm-vnc-grid">
                @for (int i = 0; i < soLuong; i++)
                {
                    for (int j = 0; j < 3; j++)
                    {
                        idx++;
                        var v = idx < count ? Model.FirstOrDefault(p => p.TT == idx) : null;
                        var hasVnc = v != null && v.tbComputer != null && v.AspNetUser != null && !string.IsNullOrEmpty(v.tbComputer.VncUri);
                        <div class="ttm-vnc-cell @(hasVnc ? "has-vnc" : "")">
                            <div class="ttm-vnc-wrap">
                                @if (hasVnc)
                                {
                                    <iframe src="@v.tbComputer.VncUri" title="@(v.AspNetUser.Email)"></iframe>
                                }
                            </div>
                            <div class="ttm-vnc-label">
                                @if (hasVnc)
                                {
                                    <a href="@v.tbComputer.VncUri" target="_blank">@v.AspNetUser.Email</a>
                                }
                                else if (v?.AspNetUser != null)
                                {
                                    @v.AspNetUser.Email
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
