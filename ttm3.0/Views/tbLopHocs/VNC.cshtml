@model IEnumerable<ttm3._0.Models.tbHocVienLopHoc>

@{
    ViewBag.Title = "Theo dõi màn hình sinh viên";
    int count = (int)ViewBag.Count;
    int soLuong = (int)ViewBag.SoLuong;
    int idx = -1;
}

<link href="~/Content/lophoc.css" rel="stylesheet" />

<style>
    .lh-vnc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; max-width: 1100px; }
    .lh-vnc-cell {
        border: 1px solid var(--sidebar-border, #e5e7eb);
        border-radius: 12px;
        overflow: hidden;
        background: var(--primary-light, #f8f9fa);
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }
    .lh-vnc-cell.has-vnc { border-color: rgba(0, 168, 255, 0.3); }
    .lh-vnc-cell .lh-vnc-wrap { position: relative; width: 100%; padding-top: 100%; background: #1a1a1a; }
    .lh-vnc-cell iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; display: block; }
    .lh-vnc-cell .lh-vnc-label {
        padding: 8px 12px;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-secondary, #4a5568);
        background: var(--primary-white, #fff);
        border-top: 1px solid var(--sidebar-border, #e5e7eb);
    }
    .lh-vnc-cell .lh-vnc-label a { color: var(--accent-cyan, #00a8ff); text-decoration: none; }
    .lh-vnc-cell .lh-vnc-label a:hover { text-decoration: underline; }
</style>

<div class="lh-page">
    <div class="lh-card">
        <div class="lh-header">
            <div class="lh-header-left">
                <div class="lh-icon"><i class="fas fa-desktop"></i></div>
                <div>
                    <h1 class="lh-title">@ViewBag.Title</h1>
                    <p class="lh-subtitle">Xem màn hình VNC của từng máy sinh viên. Click vào link để mở cửa sổ riêng.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("HocVien", "tbLopHocs", new { IdLopHoc = ViewBag.IdLopHoc })" class="lh-btn lh-btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
            </div>
        </div>
        <div class="lh-body">
            <div class="lh-vnc-grid">
                @for (int i = 0; i < soLuong; i++)
                {
                    for (int j = 0; j < 3; j++)
                    {
                        idx++;
                        var v = idx < count ? Model.FirstOrDefault(p => p.TT == idx) : null;
                        var hasVnc = v != null && v.tbComputer != null && v.AspNetUser != null && !string.IsNullOrEmpty(v.tbComputer.VncUri);
                        <div class="lh-vnc-cell @(hasVnc ? "has-vnc" : "")">
                            <div class="lh-vnc-wrap">
                                @if (hasVnc)
                                {
                                    <iframe src="@v.tbComputer.VncUri" title="@(v.AspNetUser.Email)"></iframe>
                                }
                            </div>
                            <div class="lh-vnc-label">
                                @if (hasVnc)
                                {
                                    <a href="@v.tbComputer.VncUri" target="_blank">@v.AspNetUser.Email</a>
                                }
                                else if (v?.AspNetUser != null)
                                {
                                    @v.AspNetUser.Email
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
