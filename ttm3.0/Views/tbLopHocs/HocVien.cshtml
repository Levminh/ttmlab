@model IEnumerable<ttm3._0.Models.tbHocVienLopHoc>

@{
    ViewBag.Title = "Danh sách học viên trong lớp";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />

<style>
    .ttm-dropdown .ttm-btn-drop::after { font-family: 'Font Awesome 5 Free'; font-weight: 900; }
</style>

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-users"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Quản lý học viên, máy tính và điểm.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("Index")" class="ttm-btn ttm-btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="ttm-toolbar">
                <a href="@Url.Action("HocVienAdd", new { IdLopHoc = ViewBag.IdLopHoc })" class="ttm-btn ttm-btn-add"><i class="fas fa-user-plus"></i> Thêm học viên</a>
                <a href="@Url.Action("Create", "clTaiKhoans", new { IdLopHoc = ViewBag.IdLopHoc })" class="ttm-btn ttm-btn-secondary"><i class="fas fa-user-plus"></i> Tạo tài khoản học viên</a>
                @if (ViewBag.CoQuyen == true)
                {
                    <details class="ttm-dropdown">
                        <summary class="ttm-btn ttm-btn-add ttm-btn-drop">Thao tác máy tính sinh viên</summary>
                        <div class="ttm-dropdown-menu">
                            <a href="@Url.Action("StartAll", new { IdLopHoc = ViewBag.IdLopHoc })"><i class="fas fa-play"></i> Khởi động tất cả máy</a>
                            <a href="@Url.Action("StopAll", new { IdLopHoc = ViewBag.IdLopHoc })"><i class="fas fa-stop"></i> Tắt tất cả máy</a>
                            <a href="@Url.Action("VNC", new { IdLopHoc = ViewBag.IdLopHoc })"><i class="fas fa-desktop"></i> VNC</a>
                            <a href="@Url.Action("CapMay", new { IdLopHoc = ViewBag.IdLopHoc })"><i class="fas fa-cogs"></i> Cấp máy tự động</a>
                        </div>
                    </details>
                }
                <span class="ttm-note">* Mật khẩu reset: @@Abc123</span>
            </div>
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table display table table-bordered" id="table_tbHocVien">
                    <thead>
                        <tr>
                            <th class="ttm-col-tt" style="width:36px;">TT</th>
                            <th>@Html.DisplayNameFor(model => model.AspNetUser.FullName)</th>
                            <th>Tài khoản</th>
                            <th>@Html.DisplayNameFor(model => model.TongDiem)</th>
                            <th>Computer</th>
                            <th>Status</th>
                            <th>@Html.DisplayNameFor(model => model.GhiChu)</th>
                            <th class="ttm-col-actions" style="min-width:130px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var linkDelete = Url.Action("HocVienDelete", "tbLopHocs", new { IdHocVienLopHoc = item.IdHocVienLopHoc });
                            var linkStart = Url.Action("StartOrStop", "tbLopHocs", new { IdHocVienLopHoc = item.IdHocVienLopHoc });
                            var linkReset = Url.Action("ResetPassword", "tbLopHocs", new { IdHocVienLopHoc = item.IdHocVienLopHoc });
                            <tr>
                                <td class="ttm-col-tt"></td>
                                <td>@(item.AspNetUser?.FullName)</td>
                                <td>@(item.AspNetUser?.UserName)</td>
                                <td>@Html.DisplayFor(m => item.TongDiem)</td>
                                <td class="editable-select" id="@item.IdHocVienLopHoc">@(item.tbComputer?.Name)</td>
                                <td>@(item.tbComputer?.Status)</td>
                                <td class="editable" id="@item.IdHocVienLopHoc">@(item.GhiChu)</td>
                                <td class="ttm-col-actions">
                                    <div class="ttm-actions">
                                        <a href="@linkDelete" class="ttm-act ttm-act-del" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                        @if (item.tbComputer != null && ViewBag.CoQuyen == true)
                                        {
                                            if (item.tbComputer.Status == "ACTIVE")
                                            {
                                                <a href="@linkStart" class="ttm-act" title="Tắt máy"><i class="fas fa-stop"></i></a>
                                                <a href="@(item.tbComputer.VncUri)" class="ttm-act" title="VNC" target="_blank"><i class="fas fa-external-link-alt"></i></a>
                                            }
                                            else
                                            {
                                                <a href="@linkStart" class="ttm-act" title="Bật máy"><i class="fas fa-play"></i></a>
                                            }
                                        }
                                        <a href="@linkReset" class="ttm-act" title="Đặt lại mật khẩu"><i class="fas fa-key"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    <script src="~/Scripts/jquery.jeditable.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(function () {
            var t = $('#table_tbHocVien').DataTable({
                pageLength: 50,
                columnDefs: [{ searchable: false, orderable: false, targets: 0 }, { orderable: false, targets: -1 }],
                order: [[1, 'asc']],
                language: { search: 'Tìm kiếm:', lengthMenu: 'Hiển thị _MENU_ dòng', info: 'Đang xem _START_–_END_ / _TOTAL_ dòng', infoEmpty: 'Không có dữ liệu', infoFiltered: '(lọc từ _MAX_ dòng)', zeroRecords: 'Không tìm thấy kết quả', paginate: { first: 'Đầu', last: 'Cuối', next: 'Sau', previous: 'Trước' } }
            });
            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) { cell.innerHTML = i + 1; });
            }).draw();
            $(".editable").editable("/tbLopHocs/UpdateGhiChu", { type: "textarea", width: 300, submit: 'OK', cancel: 'Hủy', data: function (s) { return $.trim(s); } });
            $(".editable-select").editable("/tbLopHocs/UpdateComputer", { type: "select", loadurl: "/tbLopHocs/LoadComputerAsync", loadtype: 'GET', loaddata: { Id: function () { return this.id; } }, submit: "OK", style: "inherit" });
        });
    </script>
}
