@model IEnumerable<ttm3._0.Models.tbLopHoc>
@{
    ViewBag.Title = "Danh sách các lớp tham gia của sinh viên";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-graduation-cap"></i></div>
                <div>
                    <h1 class="ttm-title">Lớp học của bạn</h1>
                    <p class="ttm-subtitle">Chọn lớp học để xem các kịch bản và bài tập.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @if (Model != null && Model.Any())
            {
                <div class="ttm-stats-bar">
                    <div class="ttm-stat-item">
                        <div class="ttm-stat-value">@Model.Count()</div>
                        <div class="ttm-stat-label">Tổng số lớp</div>
                    </div>
                    <div class="ttm-stat-item">
                        <div class="ttm-stat-value"><i class="fas fa-check-circle"></i></div>
                        <div class="ttm-stat-label">Đang hoạt động</div>
                    </div>
                    <div class="ttm-stat-item">
                        <div class="ttm-stat-value"><i class="fas fa-rocket"></i></div>
                        <div class="ttm-stat-label">Sẵn sàng học tập</div>
                    </div>
                </div>

                <div class="ttm-classes-grid">
                    @{
                        var iconList = new[] { "fa-laptop-code", "fa-shield-alt", "fa-network-wired", "fa-server", "fa-lock", "fa-terminal", "fa-code-branch", "fa-database" };
                        var index = 0;
                    }
                    @foreach (var item in Model)
                    {
                        <a href="/SinhVien/KichBan/?IdLopHoc=@item.IdLopHoc" class="ttm-class-card">
                            <div class="ttm-class-card-header">
                                <div class="ttm-class-icon">
                                    <i class="fas @iconList[index % iconList.Length]"></i>
                                </div>
                                <h3 class="ttm-class-name">@item.LopHoc</h3>
                            </div>
                            <div class="ttm-class-card-body">
                                <div class="ttm-class-meta">
                                    <span><i class="fas fa-book"></i> Kịch bản thực hành</span>
                                    <span><i class="fas fa-users"></i> Lớp học</span>
                                </div>
                                <div class="ttm-class-action">
                                    <span class="ttm-class-meta">
                                        <i class="fas fa-circle" style="font-size: 0.5rem; color: var(--accent-green, #059669);"></i>
                                        <span style="color: var(--accent-green, #059669);">Đang hoạt động</span>
                                    </span>
                                    <span class="ttm-btn-enter">
                                        Vào lớp
                                        <i class="fas fa-arrow-right"></i>
                                    </span>
                                </div>
                            </div>
                        </a>
                        index++;
                    }
                </div>
            }
            else
            {
                <div class="ttm-empty-state">
                    <i class="fas fa-inbox"></i>
                    <h3>Chưa có lớp học nào</h3>
                    <p>Bạn chưa được thêm vào lớp học nào. Vui lòng liên hệ với giảng viên.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
