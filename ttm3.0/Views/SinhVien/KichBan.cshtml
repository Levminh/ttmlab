@model IEnumerable<ttm3._0.Models.tbKichBan>

@{
    ViewBag.Title = "Kịch bản trong lớp học";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-list-alt"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Xem nội dung và nộp kết quả kịch bản.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("Index", "SinhVien")" class="ttm-btn ttm-btn-secondary">
                    <i class="fas fa-arrow-left"></i>
                    <span>Quay lại</span>
                </a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="ttm-card" style="margin-bottom: 1.5rem; border-radius: 12px; overflow: hidden;">
                <div class="ttm-header" style="background: linear-gradient(135deg, rgba(0, 168, 255, 0.2), rgba(0, 102, 255, 0.15));">
                    <h2 class="ttm-title" style="margin: 0;">THÔNG TIN CƠ BẢN</h2>
                </div>
                <div class="ttm-body">
                    <p><a href="@ViewBag.VNC" class="ttm-btn ttm-btn-secondary" style="display: inline-flex;"><i class="fas fa-desktop"></i> Máy tính cho sinh viên sử dụng VNC</a></p>
                    @Html.Raw(ViewBag.GhiChu)
                </div>
            </div>

            @foreach (var item in Model)
            {
                var linksubmit = item.IdKieuDanhGia == 1 ? "/tbKetQuas/ctf/?IdKetQua=" + item.IdKetQua : "/tbKetQuas/UploadFiles/?IdKetQua=" + item.IdKetQua;
                <div class="ttm-card" style="margin-bottom: 1.5rem; border-radius: 12px; overflow: hidden;">
                    <div class="ttm-header" style="background: linear-gradient(135deg, rgba(245, 222, 179, 0.4), rgba(255, 228, 181, 0.3));">
                        <div class="ttm-header-left">
                            <div class="ttm-icon" style="background: linear-gradient(135deg, #e8b923, #d4a017);"><i class="fas fa-file-code"></i></div>
                            <div>
                                <h2 class="ttm-title" style="margin: 0;">Kịch bản: @item.TenKichBan</h2>
                                <p class="ttm-subtitle" style="margin: 0.25rem 0 0;">Điểm đã đạt: @item.Diem</p>
                                <p style="margin: 0.5rem 0 0;"><a href="@linksubmit" target="_blank" class="ttm-btn ttm-btn-add" style="display: inline-flex; font-size: 0.85rem;"><i class="fas fa-paper-plane"></i> Submit kết quả</a></p>
                            </div>
                        </div>
                    </div>
                    <div class="ttm-body">
                        <h4 style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 0.5rem;">MỤC TIÊU</h4>
                        @Html.Raw(item.MucTieu)
                        <hr style="margin: 1rem 0;" />
                        <h4 style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 0.5rem;">MÔ TẢ</h4>
                        @Html.Raw(item.NoiDung)
                        <hr style="margin: 1rem 0;" />
                        <h4 style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 0.5rem;">YÊU CẦU</h4>
                        @Html.Raw(item.YeuCau)
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        
    </script>
}