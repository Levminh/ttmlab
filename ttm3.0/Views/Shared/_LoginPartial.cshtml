@using Microsoft.AspNet.Identity
@if (Request.IsAuthenticated)
{
    using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm", @class = "navbar-right" }))
    {
        @Html.AntiForgeryToken()

        <div class="user-card" id="userCard" onclick="toggleUserDropdown()">
            <div class="user-avatar">
                @{ 
                    var userName = User.Identity.GetUserName();
                    var initial = !string.IsNullOrEmpty(userName) ? userName.Substring(0, 1).ToUpper() : "U";
                }
                @initial
            </div>
            <span class="user-name">@userName</span>
            <i class="fas fa-chevron-down"></i>
        </div>
        <div class="user-dropdown" id="userDropdown">
            <a href="@Url.Action("ChangePassword", "Manage")" class="user-dropdown-item" title="Đổi mật khẩu">
                <i class="fas fa-key"></i>
                <span>Đổi mật khẩu</span>
            </a>
            <a href="javascript:document.getElementById('logoutForm').submit()" class="user-dropdown-item logout" title="Đăng xuất">
                <i class="fas fa-sign-out-alt"></i>
                <span>Đăng xuất</span>
            </a>
        </div>
        
        <script>
            function toggleUserDropdown() {
                var dropdown = document.getElementById('userDropdown');
                var card = document.getElementById('userCard');
                dropdown.classList.toggle('show');
                card.classList.toggle('active');
            }
            
            // Đóng dropdown khi click bên ngoài
            document.addEventListener('click', function(event) {
                var card = document.getElementById('userCard');
                var dropdown = document.getElementById('userDropdown');
                if (card && dropdown && !card.contains(event.target) && !dropdown.contains(event.target)) {
                    dropdown.classList.remove('show');
                    card.classList.remove('active');
                }
            });
        </script>
    }
}
else
{
    <a href="@Url.Action("Login", "Account")" class="user-card" id="loginLink" style="text-decoration: none;">
        <i class="fas fa-sign-in-alt" style="color: var(--primary-blue);"></i>
        <span class="user-name">Đăng nhập</span>
    </a>
}
