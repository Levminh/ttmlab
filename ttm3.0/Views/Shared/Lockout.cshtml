@model System.Web.Mvc.HandleErrorInfo

@{
    ViewBag.Title = "Tài khoản bị khóa";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-lock"></i></div>
                <div>
                    <h1 class="ttm-title">Tài khoản bị khóa</h1>
                    <p class="ttm-subtitle">Tài khoản này đã bị khóa. Vui lòng thử lại sau.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            <p class="ttm-status-msg ttm-status-warn">
                <i class="fas fa-exclamation-circle"></i>
                Bạn đã vượt quá số lần đăng nhập sai. Vui lòng đợi một lúc rồi thử lại.
            </p>
        </div>
    </div>
</div>

<style>
    .ttm-status-warn {
        background: rgba(251, 191, 36, 0.12) !important;
        border-color: rgba(251, 191, 36, 0.3) !important;
        color: #fde047 !important;
    }
    .ttm-status-warn i { color: #facc15; }
</style>
