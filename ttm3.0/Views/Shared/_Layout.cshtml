        }

        .main .dataTables_paginate .paginate_button,
        .main .ttm-body .dataTables_paginate .paginate_button,
        .main .dataTables_paginate .paginate_button a,
        .main .ttm-body .dataTables_paginate .paginate_button a {
            color: #e5f2ff !important;
        }

        .main .dataTables_paginate .paginate_button:hover:not(.disabled):not(.current),
        .main .ttm-body .dataTables_paginate .paginate_button:hover:not(.disabled):not(.current) {
            background: var(--cyan-dim) !important;
            color: #38bdf8 !important;
            border-color: var(--border) !important;
        }

        .main .dataTables_paginate .paginate_button.current,
        .main .dataTables_paginate .paginate_button.current:hover,
        .main .ttm-body .dataTables_paginate .paginate_button.current,
        .main .ttm-body .dataTables_paginate .paginate_button.current:hover,
        .main .dataTables_paginate .paginate_button.current a,
        .main .ttm-body .dataTables_paginate .paginate_button.current a {
