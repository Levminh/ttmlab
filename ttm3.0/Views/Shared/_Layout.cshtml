            border-color: var(--cyan) !important;
        }

        .main .dataTables_paginate .paginate_button.disabled,
        .main .ttm-body .dataTables_paginate .paginate_button.disabled,
        .main .dataTables_paginate .paginate_button.disabled a,
        .main .dataTables_paginate .paginate_button.disabled span,
        .main .ttm-body .dataTables_paginate .paginate_button.disabled span,
        .main .dataTables_paginate .paginate_button.disabled *,
        .main .ttm-body .dataTables_paginate .paginate_button.disabled * {
            color: #e5f2ff !important;
        }

        .main .dataTables_paginate .paginate_button:not(.current):not(.disabled) *,
        .main .ttm-body .dataTables_paginate .paginate_button:not(.current):not(.disabled) * {
