<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>THAO TRƯỜNG MẠNG - Cyber Training Platform</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    @* Theme chung của hệ thống *@
    <link href="~/Content/ttm-theme.css" rel="stylesheet" />

    <style>
        :root {
            --bg-deep: #050816;
            --bg-panel: #08121f;
            --bg-card: #0b1726;
            --border: rgba(56, 189, 248, 0.22);
            --border-lit: rgba(56, 189, 248, 0.6);
            --cyan: #38bdf8;
            --cyan-dim: rgba(56, 189, 248, 0.2);
            --cyan-glow: rgba(56, 189, 248, 0.45);
            --green: #4ade80;
            --amber: #facc15;
            --red: #fb7185;
            --text-bright: #e5f2ff;
            --text-mid: #cbd5f5;
            --text-dim: #8ea2c0;
            --font-ui: 'Sora', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --sidebar-w: 260px;
            --sidebar-collapsed: 68px;
            --transition: 0.28s cubic-bezier(0.4, 0, 0.2, 1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background: radial-gradient(circle at 0% 0%, #0b1120 0, #020617 38%, #000 100%);
            color: var(--text-bright);
            min-height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* ===================== SIDEBAR ===================== */
        .sidebar {
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--bg-panel);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            left: 0;
            top: 0;
            z-index: 100;
            transition: width var(--transition);
            overflow: hidden;
        }

        .sidebar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 1px;
            height: 100%;
            background: linear-gradient(180deg, transparent 0%, var(--cyan) 30%, var(--cyan) 70%, transparent 100%);
            opacity: 0;
            transition: opacity 0.4s;
        }

        .sidebar:hover::before {
            opacity: 0.6;
        }

        /* --- Brand --- */
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 22px 20px;
            margin: 12px 10px 14px;
            min-height: 72px;
            border-radius: 12px;
            text-decoration: none;
            position: relative;
            overflow: hidden;
            flex-shrink: 0;
            background: linear-gradient(135deg, rgba(8, 34, 58, 0.6) 0%, rgba(4, 18, 32, 0.8) 100%);
            border: 1px solid rgba(56, 189, 248, 0.2);
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .sidebar-brand::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 3px;
            height: 100%;
            background: linear-gradient(180deg, var(--cyan), transparent 70%);
            border-radius: 3px 0 0 3px;
            opacity: 0.9;
        }

        .sidebar-brand:hover {
            border-color: rgba(56, 189, 248, 0.4);
            box-shadow: 0 0 20px rgba(56, 189, 248, 0.08);
        }

        .brand-icon {
            width: 42px;
            height: 42px;
            flex-shrink: 0;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .brand-icon svg {
            width: 42px;
            height: 42px;
            filter: drop-shadow(0 0 8px rgba(56, 189, 248, 0.3));
        }

        .brand-icon .hex-bg {
            fill: none;
            stroke: var(--cyan);
            stroke-width: 1.8;
            opacity: 0.85;
            transition: opacity 0.2s;
        }

        .brand-icon .hex-inner {
            fill: rgba(8, 34, 58, 0.9);
        }

        .sidebar-brand:hover .brand-icon .hex-bg {
            opacity: 1;
        }

        .brand-icon i {
            position: absolute;
            color: var(--cyan);
            font-size: 15px;
            filter: drop-shadow(0 0 8px rgba(56, 189, 248, 0.5));
        }

        .brand-text {
            flex: 1;
            min-width: 0;
            display: flex;
            align-items: center;
        }

        .brand-title {
            font-family: var(--font-mono);
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-bright);
            letter-spacing: 0.06em;
            text-transform: uppercase;
            white-space: nowrap;
            display: block;
            line-height: 1.2;
        }

        .brand-status {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-shrink: 0;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 8px rgba(34, 197, 94, 0.6);
            animation: pulse-dot 2.5s ease-in-out infinite;
        }

        @@keyframes pulse-dot {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(0.8);
            }
        }

        .nav-list {
            list-style: none;
            padding: 4px 10px;
            flex-shrink: 0;
        }

        .nav-item {
            margin-bottom: 2px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 10px;
            border-radius: 8px;
            text-decoration: none;
            color: var(--text-mid);
            font-size: 0.92rem;
            font-weight: 500;
            position: relative;
            transition: all var(--transition);
            white-space: nowrap;
            overflow: hidden;
            cursor: pointer;
            border: 1px solid transparent;
            background: transparent;
            width: 100%;
            text-align: left;
            font-family: var(--font-ui);
        }

        .nav-link::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%) scaleY(0);
            width: 2px;
            height: 60%;
            background: var(--cyan);
            border-radius: 0 2px 2px 0;
            transition: transform var(--transition);
            box-shadow: 0 0 8px var(--cyan);
        }

        .nav-link:hover {
            color: var(--text-bright);
            background: var(--cyan-dim);
            border-color: var(--border-lit);
        }

        .nav-link:hover::before {
            transform: translateY(-50%) scaleY(1);
        }

        .nav-link.active {
            color: var(--cyan);
            background: linear-gradient(90deg, rgba(0, 200, 255, 0.12), rgba(0, 200, 255, 0.04));
            border-color: var(--border-lit);
            font-weight: 600;
        }

        .nav-link.active::before {
            transform: translateY(-50%) scaleY(1);
        }

        .nav-icon {
            width: 32px;
            height: 32px;
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.95rem;
            flex-shrink: 0;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all var(--transition);
            color: var(--text-dim);
            position: relative;
        }

        .nav-link:hover .nav-icon {
            background: rgba(0, 200, 255, 0.12);
            border-color: rgba(0, 200, 255, 0.3);
            color: var(--cyan);
            box-shadow: 0 0 12px rgba(0, 200, 255, 0.2);
        }

        .nav-link.active .nav-icon {
            background: rgba(0, 200, 255, 0.15);
            border-color: rgba(0, 200, 255, 0.4);
            color: var(--cyan);
            box-shadow: 0 0 16px rgba(0, 200, 255, 0.25);
        }

        .nav-badge {
            margin-left: auto;
            font-family: var(--font-mono);
            font-size: 0.7rem;
            padding: 2px 6px;
            border-radius: 20px;
            background: rgba(0, 200, 255, 0.15);
            border: 1px solid rgba(0, 200, 255, 0.3);
            color: var(--cyan);
            letter-spacing: 0.05em;
            flex-shrink: 0;
        }

        .nav-badge.red {
            background: rgba(255, 77, 106, 0.15);
            border-color: rgba(255, 77, 106, 0.3);
            color: var(--red);
        }

        .nav-badge.green {
            background: rgba(0, 255, 157, 0.12);
            border-color: rgba(0, 255, 157, 0.3);
            color: var(--green);
        }

        .nav-chevron {
            margin-left: auto;
            font-size: 0.75rem;
            color: var(--text-dim);
            transition: transform var(--transition);
            flex-shrink: 0;
        }

        .nav-link[aria-expanded="true"] .nav-chevron {
            transform: rotate(90deg);
            color: var(--cyan);
        }

        .submenu {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            padding-left: 10px;
        }

        .submenu.open {
            max-height: 300px;
        }

        .submenu-inner {
            padding: 4px 0 6px;
        }

        .submenu-link {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px 8px 16px;
            font-size: 0.88rem;
            color: var(--text-dim);
            text-decoration: none;
            border-radius: 6px;
            transition: all var(--transition);
            position: relative;
            font-family: var(--font-ui);
        }

        .submenu-link::before {
            content: '';
            position: absolute;
            left: 6px;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: var(--text-dim);
            transition: all var(--transition);
        }

        .submenu-link:hover {
            color: var(--cyan);
            background: rgba(0, 200, 255, 0.06);
        }

        .submenu-link:hover::before {
            background: var(--cyan);
            box-shadow: 0 0 6px var(--cyan);
        }

        .nav-divider {
            height: 1px;
            margin: 8px 12px;
            background: linear-gradient(90deg, transparent, var(--border), transparent);
            flex-shrink: 0;
        }

        .nav-scroll {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            scrollbar-width: thin;
            scrollbar-color: rgba(0, 200, 255, 0.2) transparent;
        }

        .nav-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .nav-scroll::-webkit-scrollbar-thumb {
            background: rgba(0, 200, 255, 0.2);
            border-radius: 2px;
        }

        .sidebar-footer {
            border-top: 1px solid var(--border);
            padding: 10px 10px 12px;
            flex-shrink: 0;
        }

        .user-shell {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            padding: 12px 10px 10px;
            border-radius: 12px;
            border: 1px solid rgba(0, 200, 255, 0.14);
            background: radial-gradient(circle at 0 0, rgba(0, 200, 255, 0.12), transparent 55%);
            box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.9), 0 14px 30px rgba(15, 23, 42, 0.9);
            cursor: default;
        }

        .user-shell-avatar {
            width: 40px;
            height: 40px;
            border-radius: 999px;
            background: radial-gradient(circle at 30% 0, #e0f2fe, #0ea5e9 35%, #0369a1 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: #e5f2ff;
            flex-shrink: 0;
            box-shadow: 0 0 14px rgba(56, 189, 248, 0.9);
        }

        .user-shell-name {
            width: 100%;
            font-size: 0.9rem;
            font-weight: 600;
            letter-spacing: 0.02em;
            color: var(--text-bright);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            text-align: center;
        }

        .user-shell-actions {
            display: flex;
            flex-direction: column;
            gap: 6px;
            flex-shrink: 0;
            width: 100%;
        }

        .user-shell-actions a {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 7px 10px;
            border-radius: 8px;
            border: 1px solid rgba(148, 163, 184, 0.35);
            background: rgba(15, 23, 42, 0.9);
            color: var(--text-mid);
            font-size: 0.8rem;
            text-decoration: none;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .user-shell-actions a:hover {
            border-color: rgba(56, 189, 248, 0.9);
            color: var(--cyan);
            box-shadow: 0 0 10px rgba(56, 189, 248, 0.6);
            background: radial-gradient(circle at 0 0, rgba(8, 47, 73, 0.9), rgba(15, 23, 42, 1));
        }

        .user-shell-actions a.logout:hover {
            border-color: rgba(248, 113, 113, 0.9);
            color: #fecaca;
            box-shadow: 0 0 10px rgba(248, 113, 113, 0.7);
        }


        .sidebar-toggle-btn {
            position: absolute;
            top: 50%;
            right: -16px;
            transform: translateY(-50%);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(180deg, rgba(8, 34, 58, 0.98) 0%, rgba(4, 18, 32, 0.98) 100%);
            border: 1px solid rgba(56, 189, 248, 0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--cyan);
            font-size: 0.75rem;
            transition: border-color 0.2s, background 0.2s, color 0.2s, box-shadow 0.2s, transform 0.2s;
            z-index: 10;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(0, 0, 0, 0.2);
            outline: none;
        }

        .sidebar-toggle-btn:hover {
            background: rgba(56, 189, 248, 0.2);
            border-color: var(--cyan);
            color: var(--text-bright);
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.4), 0 0 20px rgba(56, 189, 248, 0.25);
        }

        .sidebar-toggle-btn:active {
            transform: translateY(-50%) scale(0.95);
        }

        .sidebar-toggle-btn i {
            transition: transform 0.25s ease;
        }

        .sidebar.collapsed .sidebar-toggle-btn i {
            transform: rotate(180deg);
        }

        .sidebar.collapsed {
            width: var(--sidebar-collapsed);
        }

        .sidebar.collapsed .brand-text,
        .sidebar.collapsed .brand-status,
        .sidebar.collapsed .nav-link span:not(.nav-icon),
        .sidebar.collapsed .nav-badge,
        .sidebar.collapsed .nav-chevron,
        .sidebar.collapsed .submenu,
        .sidebar.collapsed .sidebar-footer {
            display: none;
        }

        .sidebar.collapsed .nav-link {
            justify-content: center;
            padding: 10px;
        }

        .sidebar.collapsed .nav-icon {
            margin: 0;
        }

        .sidebar.collapsed .sidebar-brand {
            justify-content: center;
            padding: 14px 10px;
            margin: 12px 8px 14px;
        }

        .sidebar.collapsed .nav-list {
            padding: 4px 8px;
        }

        .sidebar.collapsed .nav-scroll {
            overflow: hidden;
        }

        .sidebar.collapsed .nav-link {
            position: relative;
        }

        .sidebar.collapsed .nav-link::after {
            content: attr(data-label);
            position: absolute;
            left: calc(100% + 12px);
            top: 50%;
            transform: translateY(-50%);
            background: var(--bg-card);
            border: 1px solid var(--border-lit);
            color: var(--text-bright);
            padding: 5px 10px;
            border-radius: 6px;
            font-size: 0.85rem;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s;
            font-family: var(--font-ui);
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
        }

        .sidebar.collapsed .nav-link:hover::after {
            opacity: 1;
        }

        /* ===================== MAIN CONTENT ===================== */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            min-height: 0;
            height: 100vh;
            padding: 24px 28px;
            transition: margin-left var(--transition);
            overflow-y: auto;
            overflow-x: hidden;
        }

        .main.shifted {
            margin-left: var(--sidebar-collapsed);
        }

        .main-inner {
            max-width: 1280px;
            margin: 0 auto;
            min-height: min-content;
        }

        .content-card {
            background: rgba(15, 23, 42, 0.88);
            border-radius: 16px;
            border: 1px solid rgba(148, 163, 184, 0.25);
            box-shadow: 0 24px 80px rgba(15, 23, 42, 0.85);
            padding: 20px 24px 24px;
        }

        .sticky-footer {
            margin-top: 16px;
            padding-top: 12px;
            border-top: 1px solid rgba(148, 163, 184, 0.25);
            font-size: 0.9rem;
            color: var(--text-dim);
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .sticky-footer .footer-brand {
            color: var(--text-bright);
            font-weight: 600;
        }

        .sticky-footer .footer-sep {
            opacity: 0.6;
        }

        .main .container-fluid {
            padding: 0;
            background: transparent !important;
        }

        .main .main-inner {
            background: transparent !important;
        }

        @@media (max-width: 768px) {
            body {
                overflow: auto;
            }

            .sidebar {
                position: fixed;
                z-index: 120;
            }

            .main,
            .main.shifted {
                margin-left: var(--sidebar-w);
                padding: 20px 16px;
            }
        }

        @@keyframes scan {
            0% {
                background-position: 0 -100%;
            }

            100% {
                background-position: 0 200%;
            }
        }

        .nav-link.active::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 8px;
            background: linear-gradient(180deg, transparent 40%, rgba(0, 200, 255, 0.04) 50%, transparent 60%);
            background-size: 100% 200%;
            animation: scan 3s linear infinite;
            pointer-events: none;
        }

        /* ===================== CONTENT THEME (đồng bộ với sidebar Dark Cyber) ===================== */
        .main {
            color: var(--text-bright);
            background: var(--bg-deep) !important;
        }

        .main h1, .main h2, .main h3, .main h4 {
            color: var(--text-bright) !important;
            font-weight: 600;
        }

        .main p, .main .ttm-page {
            color: var(--text-mid) !important;
        }

        .main a:not(.ttm-btn):not(.btn) {
            color: var(--cyan);
            text-decoration: none;
        }

        .main a:not(.ttm-btn):not(.btn):hover {
            color: var(--text-bright);
            text-decoration: underline;
        }

        .main .content-card {
            background: var(--bg-panel) !important;
            border: 1px solid var(--border);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        }

        .main .ttm-card {
            background: var(--bg-card) !important;
            border: 1px solid var(--border);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }

        .main .ttm-header {
            background: rgba(56, 189, 248, 0.12) !important;
            border-bottom: 1px solid var(--border) !important;
        }

        .main .ttm-title {
            color: var(--text-bright) !important;
        }

        .main .ttm-subtitle {
            color: var(--text-mid) !important;
        }

        .main .ttm-body {
            background: var(--bg-card) !important;
        }

        .main .ttm-card .ttm-card-header,
        .main .ttm-toolbar {
            background: rgba(56, 189, 248, 0.08) !important;
            border-bottom: 1px solid var(--border);
            color: var(--text-bright);
        }

        .main .ttm-table-wrap,
        .main .table-responsive {
            background: var(--bg-card) !important;
            border: 1px solid var(--border) !important;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
        }

        .main .ttm-table,
        .main .dataTable {
            table-layout: fixed;
            width: 100%;
        }

        .main .ttm-table thead,
        .main .dataTable thead,
        .main table thead {
            background: linear-gradient(180deg, rgba(4, 14, 26, 0.98) 0%, rgba(2, 8, 16, 0.98) 100%) !important;
            border-bottom: 2px solid var(--border-lit) !important;
        }

        .main .ttm-table thead th,
        .main .dataTable thead th,
        .main table thead th {
            color: var(--text-bright) !important;
            font-weight: 600 !important;
            font-size: 0.75rem !important;
            letter-spacing: 0.06em !important;
            text-transform: uppercase !important;
            text-align: center !important;
            padding: 12px 10px !important;
            border: none !important;
            border-bottom: 1px solid rgba(56, 189, 248, 0.35) !important;
            border-right: 1px solid rgba(56, 189, 248, 0.4) !important;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .main .ttm-table thead th:last-child,
        .main .dataTable thead th:last-child,
        .main table thead th:last-child {
            border-right: none !important;
        }

        .main .ttm-table tbody tr,
        .main .dataTable tbody tr,
        .main table tbody tr {
            border-bottom: 1px solid rgba(56, 189, 248, 0.35);
        }

        .main .ttm-table tbody td,
        .main .dataTable tbody td,
        .main table tbody td {
            color: var(--text-mid) !important;
            background: var(--bg-card) !important;
            border: 1px solid rgba(56, 189, 248, 0.35) !important;
            border-top: none !important;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .main .ttm-table tbody td:first-child,
        .main .dataTable tbody td:first-child,
        .main table tbody td:first-child {
            border-left: none !important;
            width: 1%;
            min-width: 36px;
            max-width: 56px;
            text-align: center;
        }

        .main .ttm-table tbody td:last-child,
        .main .dataTable tbody td:last-child,
        .main table tbody td:last-child {
            border-right: none !important;
            min-width: 120px;
            white-space: normal;
        }

        .main .ttm-table tbody tr:hover td,
        .main .dataTable tbody tr:hover td,
        .main table tbody tr:hover td {
            background: rgba(8, 34, 64, 0.9) !important;
            color: var(--text-bright) !important;
        }

        .main .ttm-table tbody tr.even:hover td,
        .main .dataTable tbody tr.even:hover td,
        .main table tbody tr.even:hover td {
            background: rgba(8, 34, 64, 0.9) !important;
            color: var(--text-bright) !important;
        }

        .main .ttm-table tbody tr.even td,
        .main .dataTable tbody tr.even td,
        .main table tbody tr.even td {
            background: var(--bg-card) !important;
        }

        /* Cột tên dài: một dòng + ellipsis, tránh hàng cao lệch */
        .main .ttm-table tbody td:nth-child(3),
        .main .dataTable tbody td:nth-child(3),
        .main table tbody td:nth-child(3) {
            max-width: 320px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .main .ttm-table thead th:nth-child(3),
        .main .dataTable thead th:nth-child(3),
        .main table thead th:nth-child(3) {
            max-width: 320px;
        }

        /* DataTables wrapper (trang Report, v.v.) */
        .main .dataTables_wrapper {
            color: var(--text-mid) !important;
        }

        .main .dataTables_wrapper {
            grid-template-columns: 220px 1fr !important;
        }

        .main .dataTables_wrapper > .dataTables_length,
        .main .dataTables_wrapper > .dataTables_filter {
            background: rgba(6, 18, 32, 0.85) !important;
            border: 1px solid rgba(56, 189, 248, 0.2) !important;
            color: var(--text-bright) !important;
            min-height: 52px;
            padding: 0 20px !important;
            display: flex !important;
            align-items: center !important;
        }

        .main .dataTables_wrapper > .dataTables_length {
            min-width: 0;
            border-right: none !important;
            border-radius: 8px 0 0 0 !important;
            padding-right: 24px !important;
        }

        .main .dataTables_wrapper > .dataTables_filter {
            min-width: 0;
            overflow: hidden;
            border-left: 1px solid rgba(56, 189, 248, 0.15) !important;
            border-radius: 0 8px 0 0 !important;
            padding-left: 16px !important;
        }

        .main .dataTables_wrapper .dataTables_length label,
        .main .dataTables_wrapper .dataTables_filter label {
            margin: 0 !important;
            min-width: 0;
            flex: 1;
            display: flex !important;
            align-items: center !important;
            gap: 10px !important;
            font-size: 0.8rem !important;
            font-weight: 500 !important;
            color: var(--text-mid) !important;
            letter-spacing: 0.02em;
        }

        .main .dataTables_wrapper .dataTables_length label {
            flex: 0 0 auto;
        }

        .main .dataTables_filter label {
            width: 100%;
            max-width: none;
        }

        .main .dataTables_length select {
            background: rgba(8, 28, 48, 0.9) !important;
            border: 1px solid rgba(56, 189, 248, 0.25) !important;
            color: var(--text-bright) !important;
            padding: 8px 32px 8px 12px !important;
            border-radius: 6px !important;
            font-size: 0.85rem !important;
            min-height: 36px;
            flex-shrink: 0;
        }

        .main .dataTables_filter input {
            background: rgba(8, 28, 48, 0.9) !important;
            border: 1px solid rgba(56, 189, 248, 0.25) !important;
            color: var(--text-bright) !important;
            flex: 1 1 auto !important;
