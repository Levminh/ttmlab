        .main .ttm-btn-primary,
        .main .ttm-btn-add,
        .main .btn.btn-primary,
        .main .btn.btn-success {
            background: linear-gradient(135deg, var(--cyan), #0ea5e9) !important;
            color: #fff !important;
            border: none !important;
            box-shadow: 0 0 16px rgba(56, 189, 248, 0.4);
        }

        .main .ttm-btn-primary:hover,
        .main .ttm-btn-add:hover,
        .main .btn.btn-primary:hover,
        .main .btn.btn-success:hover {
            box-shadow: 0 0 22px rgba(56, 189, 248, 0.55);
            color: #fff !important;
        }

        .main .ttm-btn-secondary,
        .main .btn.btn-default:not(.btn-primary) {
            background: var(--bg-card) !important;
            color: var(--text-mid) !important;
            border: 1px solid var(--border) !important;
        }

        .main .ttm-btn-secondary:hover,
        .main .btn.btn-default:not(.btn-primary):hover {
            border-color: var(--cyan) !important;
            color: var(--cyan) !important;
            background: var(--cyan-dim) !important;
        }

        .main .ttm-btn-danger,
        .main .btn.btn-danger {
            background: linear-gradient(135deg, var(--red), #e11d48) !important;
            color: #fff !important;
        }

        .main .ttm-acts,
        .main .ttm-actions {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        .main .ttm-act {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            min-width: 32px;
            border-radius: 8px;
            color: var(--text-mid);
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border);
            text-decoration: none;
            transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .main .ttm-act:hover {
            color: var(--cyan);
            background: rgba(56, 189, 248, 0.15);
            border-color: rgba(56, 189, 248, 0.4);
            box-shadow: 0 0 12px rgba(56, 189, 248, 0.2);
        }

        .main .ttm-act i {
            font-size: 0.9rem;
        }

        .main .ttm-act.ttm-act-del:hover {
            color: #fca5a5;
            background: rgba(248, 113, 113, 0.15);
            border-color: rgba(248, 113, 113, 0.4);
            box-shadow: 0 0 12px rgba(248, 113, 113, 0.2);
        }

        .main .ttm-form label,
        .main .ttm-form .control-label {
            color: var(--text-mid);
        }

        .main .ttm-form .form-control,
        .main .ttm-form input[type="text"],
        .main .ttm-form input[type="number"],
        .main .ttm-form input[type="password"],
        .main .ttm-form input[type="email"],
        .main .ttm-form select,
        .main .ttm-form textarea {
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text-bright);
        }

        .main .ttm-form .form-control:focus,
        .main .ttm-form input:focus,
        .main .ttm-form select:focus,
        .main .ttm-form textarea:focus {
            border-color: var(--cyan);
            box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.2);
        }

        .main .ttm-form .form-control::placeholder,
        .main .ttm-form input::placeholder,
        .main .ttm-form textarea::placeholder {
            color: var(--text-dim);
        }

        .main .container-fluid .card.shadow.mb-4,
        .main .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }

        .main .container-fluid .card .card-header,
        .main .card .card-header {
            background: rgba(56, 189, 248, 0.1);
            border-bottom: 1px solid var(--border);
        }

        .main .container-fluid .card .card-header h3,
        .main .card .card-header h3 {
            color: var(--text-bright);
        }

        .main .container-fluid .card .table thead th,
        .main .card .table thead th {
            background: linear-gradient(180deg, rgba(4, 14, 26, 0.98) 0%, rgba(2, 8, 16, 0.98) 100%) !important;
            color: var(--text-bright) !important;
            font-weight: 600 !important;
            font-size: 0.75rem !important;
            letter-spacing: 0.06em !important;
            text-transform: uppercase !important;
            text-align: center !important;
            padding: 12px 10px !important;
            border-bottom: 1px solid rgba(56, 189, 248, 0.35) !important;
            border-right: 1px solid rgba(56, 189, 248, 0.4) !important;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .main .container-fluid .card .table thead th:last-child,
        .main .card .table thead th:last-child {
            border-right: none !important;
        }

        .main .container-fluid .card .table tbody td,
        .main .card .table tbody td {
            color: var(--text-mid) !important;
            border: 1px solid rgba(56, 189, 248, 0.35) !important;
            border-top: none !important;
        }

        .main .container-fluid .card .table tbody td:first-child,
        .main .card .table tbody td:first-child {
            border-left: none !important;
        }

        .main .container-fluid .card .table tbody td:last-child,
        .main .card .table tbody td:last-child {
            border-right: none !important;
        }

        .main .container-fluid .card .table tbody tr:hover,
        .main .card .table tbody tr:hover,
        .main .container-fluid .card .table tbody tr:hover td,
        .main .card .table tbody tr:hover td,
        .main .table tbody tr:hover,
        .main .table tbody tr:hover td {
            background: rgba(8, 34, 64, 0.9) !important;
            color: var(--text-bright) !important;
        }

        .main .validation-summary-errors,
        .main .text-danger ul {
            background: rgba(251, 113, 133, 0.12);
            border-color: var(--red);
            color: #fecaca;
        }

        .main .text-danger,
        .main .field-validation-error {
            color: #fca5a5;
        }

        .main .text-success {
            color: #86efac !important;
        }

        .main .ttm-status-msg {
            padding: 10px 14px;
            border-radius: 8px;
            background: rgba(74, 222, 128, 0.12);
            border: 1px solid rgba(74, 222, 128, 0.3);
            color: #86efac;
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }

        .main .form-horizontal .form-group {
            margin-bottom: 1rem;
        }

        .main .form-horizontal .control-label,
        .main .form-horizontal label.control-label {
            color: var(--text-mid) !important;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .main .form-horizontal .form-control,
        .main .form-horizontal input[type="text"],
        .main .form-horizontal input[type="password"],
        .main .form-horizontal input[type="email"],
        .main .form-horizontal input[type="file"],
        .main .form-horizontal select,
        .main .form-horizontal textarea {
            background: var(--bg-panel) !important;
            border: 1px solid var(--border) !important;
            color: var(--text-bright) !important;
        }

        .main .form-horizontal .checkbox label {
            color: var(--text-mid);
            font-weight: normal;
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <button class="sidebar-toggle-btn" id="toggleBtn" title="Thu nhỏ / Mở rộng">
            <i class="fas fa-chevron-left" id="toggleIcon"></i>
        </button>

        <a class="sidebar-brand" href="/SinhVien/" title="Thao Trường Mạng">
            <div class="brand-icon">
                <svg viewBox="0 0 38 38">
                    <polygon class="hex-inner" points="19,3 34,11 34,27 19,35 4,27 4,11" />
                    <polygon class="hex-bg" points="19,3 34,11 34,27 19,35 4,27 4,11" />
                </svg>
                <i class="fas fa-network-wired"></i>
            </div>
            <div class="brand-text">
                <span class="brand-title">Thao Trường Mạng</span>
            </div>
            <div class="brand-status">
                <span class="status-dot"></span>
            </div>
        </a>

        <div class="nav-scroll">
            <ul class="nav-list" id="adminMenu">
                <li class="nav-item">
                    <a class="nav-link" href="/tbLopHocs/" data-label="Lớp học">
                        <span class="nav-icon"><i class="fas fa-chalkboard-teacher"></i></span>
                        <span>Lớp học</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/tbKichBans/" data-label="Kịch bản">
                        <span class="nav-icon"><i class="fas fa-file-code"></i></span>
                        <span>Kịch bản</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/tbProjectOpenStacks/" data-label="Phòng Lab">
                        <span class="nav-icon"><i class="fas fa-flask"></i></span>
                        <span>Phòng Lab</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/tbSoDoMangs/" data-label="Sơ đồ mạng">
                        <span class="nav-icon"><i class="fas fa-project-diagram"></i></span>
                        <span>Sơ đồ mạng</span>
                    </a>
                </li>
            </ul>

            <div class="nav-divider"></div>

            <ul class="nav-list">
                <li class="nav-item">
                    <button type="button" class="nav-link" data-label="Thống kê" aria-expanded="false" id="statsToggle">
                        <span class="nav-icon"><i class="fas fa-chart-line"></i></span>
                        <span>Thống kê</span>
                        <i class="fas fa-chevron-right nav-chevron"></i>
                    </button>
                    <div class="submenu" id="statsMenu">
                        <div class="submenu-inner">
                            <a class="submenu-link" href="/tbKichBans/Report">Kịch bản</a>
                            <a class="submenu-link" href="/tbLopHocs/tkSinhVien">Sinh viên</a>
                        </div>
                    </div>
                </li>
            </ul>

            <div class="nav-divider"></div>

            <ul class="nav-list">
                <li class="nav-item">
                    <button type="button" class="nav-link" data-label="Giám sát" aria-expanded="false" id="monitorToggle">
                        <span class="nav-icon"><i class="fas fa-desktop"></i></span>
                        <span>Giám sát</span>
                        <i class="fas fa-chevron-right nav-chevron"></i>
                    </button>
                    <div class="submenu" id="monitorMenu">
                        <div class="submenu-inner">
                            <a class="submenu-link" href="http://gs.firmware.vn/en-US/app/crc500/c500_windowsDasboard" target="_blank">C500_Win7L6G</a>
                            <a class="submenu-link" href="http://gs.firmware.vn/en-US/app/crc500/c500_lh_ms17010" target="_blank">C500_LH_MS17-010</a>
                            <a class="submenu-link" href="http://gs.firmware.vn/en-US/app/crc500/c500_lh_lohongweb" target="_blank">C500_LH_LoHongWeb</a>
                        </div>
                    </div>
                </li>
            </ul>

            <div class="nav-divider"></div>

            <ul class="nav-list">
                <li class="nav-item">
                    <a class="nav-link" href="/AspNetUsers/" data-label="Tài khoản">
                        <span class="nav-icon"><i class="fas fa-user-shield"></i></span>
                        <span>Tài khoản</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <div class="user-shell">
                <div class="user-shell-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div class="user-shell-name" title="@User.Identity.Name">
                    @User.Identity.Name
                </div>
                <div class="user-shell-actions">
                    <a href="@Url.Content("~/Manage/ChangePassword")" title="Đổi mật khẩu">
                        <i class="fas fa-key"></i>
                        <span>Đổi mật khẩu</span>
                    </a>
                    <a href="@Url.Content("~/Account/LogOff")" class="logout" title="Đăng xuất">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Đăng xuất</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="main" id="mainContent">
        <div class="main-inner">
            <div class="content-card">
                <div class="container-fluid">
                    @RenderBody()
                </div>
                <footer class="sticky-footer">
                    <span class="footer-brand">Thao trường mạng công nghệ</span>
                    <span class="footer-sep">—</span>
                    <span>Cyber Training Platform</span>
                    <span class="footer-sep">|</span>
                    <span>© BCN Đề tài 2020</span>
                </footer>
            </div>
        </div>
    </div>

    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script>
        const sidebar = document.getElementById('sidebar');
        const toggleBtn = document.getElementById('toggleBtn');
        const toggleIcon = document.getElementById('toggleIcon');
        const mainContent = document.getElementById('mainContent');

        if (toggleBtn && sidebar && toggleIcon && mainContent) {
            toggleBtn.addEventListener('click', () => {
                const collapsed = sidebar.classList.toggle('collapsed');
                mainContent.classList.toggle('shifted', collapsed);
            });
        }

        function makeSubmenuToggle(btnId, menuId) {
            const btn = document.getElementById(btnId);
            const menu = document.getElementById(menuId);
            if (!btn || !menu) return;
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const open = menu.classList.toggle('open');
                btn.setAttribute('aria-expanded', open);
            });
        }

        makeSubmenuToggle('statsToggle', 'statsMenu');
        makeSubmenuToggle('monitorToggle', 'monitorMenu');

        document.querySelectorAll('a.nav-link').forEach(link => {
            link.addEventListener('click', function () {
                document.querySelectorAll('.nav-link.active').forEach(a => a.classList.remove('active'));
                this.classList.add('active');
            });
        });

        function applyTableCellTitles() {
            document.querySelectorAll('.main tbody td').forEach(function (td) {
                var text = (td.textContent || td.innerText || '').trim();
                if (text) td.setAttribute('title', text);
            });
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', applyTableCellTitles);
        } else {
            applyTableCellTitles();
        }
        $(document).on('draw.dt', 'table.dataTable', function () {
            applyTableCellTitles();
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>