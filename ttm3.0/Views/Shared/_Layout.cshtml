        }

        .main .dataTables_filter input::placeholder {
            color: var(--text-dim) !important;
        }

        .main .dataTables_filter input:focus {
            background: rgba(8, 28, 48, 0.95) !important;
            border-color: rgba(56, 189, 248, 0.35) !important;
            box-shadow: none !important;
        }

        .main .dataTables_wrapper > .dataTables_info,
        .main .dataTables_wrapper > .dataTables_paginate,
        .main .ttm-body .dataTables_wrapper > .dataTables_paginate {
            background: var(--bg-card) !important;
            border: 1px solid var(--border) !important;
