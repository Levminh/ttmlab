@{
    ViewBag.Title = "Truy cập bị từ chối";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-ban"></i></div>
                <div>
                    <h1 class="ttm-title">Truy cập bị từ chối</h1>
                    <p class="ttm-subtitle">Bạn không có quyền truy cập trang này.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @if (!string.IsNullOrEmpty(ViewData["Message"] as string))
            {
                <p class="ttm-status-msg ttm-status-warn">
                    <i class="fas fa-info-circle"></i>
                    @ViewData["Message"]
                </p>
            }
            <a href="@Url.Action("Index", "Home")" class="ttm-btn ttm-btn-secondary">
                <i class="fas fa-home"></i>
                <span>Về trang chủ</span>
            </a>
        </div>
    </div>
</div>

<style>
    .ttm-status-warn {
        background: rgba(251, 191, 36, 0.12) !important;
        border-color: rgba(251, 191, 36, 0.3) !important;
        color: #fde047 !important;
        margin-bottom: 1rem;
    }
    .ttm-status-warn i { color: #facc15; }
</style>
