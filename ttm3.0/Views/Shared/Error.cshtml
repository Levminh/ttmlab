@model System.Web.Mvc.HandleErrorInfo

@{
    ViewBag.Title = "Lỗi";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div>
                    <h1 class="ttm-title">Lỗi</h1>
                    <p class="ttm-subtitle">Đã xảy ra lỗi khi xử lý yêu cầu của bạn.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            <p class="ttm-error-msg">
                <i class="fas fa-info-circle"></i>
                Vui lòng thử lại hoặc liên hệ quản trị nếu lỗi tiếp tục xảy ra.
            </p>
        </div>
    </div>
</div>

<style>
    .ttm-error-msg {
        padding: 12px 16px;
        border-radius: 8px;
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid rgba(248, 113, 113, 0.3);
        color: #fca5a5;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .ttm-error-msg i { color: #f87171; }
</style>
