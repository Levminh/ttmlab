@model ttm3._0.Models.ExternalLoginListViewModel
@using Microsoft.Owin.Security

<div class="ttm-external-logins">
    <h4 class="ttm-external-logins-title">Đăng nhập bằng dịch vụ khác</h4>
    <hr class="ttm-hr" />
    @{
        var loginProviders = Context.GetOwinContext().Authentication.GetExternalAuthenticationTypes();
        if (loginProviders.Count() == 0)
        {
            <p class="ttm-status-msg ttm-status-warn">
                Chưa cấu hình dịch vụ đăng nhập bên ngoài.
            </p>
        }
        else
        {
            using (Html.BeginForm("ExternalLogin", "Account", new { ReturnUrl = Model.ReturnUrl }))
            {
                @Html.AntiForgeryToken()
                <div id="socialLoginList" class="ttm-external-logins-buttons">
                    @foreach (AuthenticationDescription p in loginProviders)
                    {
                        <button type="submit" class="ttm-btn ttm-btn-primary" id="@p.AuthenticationType" name="provider" value="@p.AuthenticationType" title="Đăng nhập bằng @p.Caption">@p.AuthenticationType</button>
                    }
                </div>
            }
        }
    }
</div>

<style>
    .ttm-external-logins { margin: 1rem 0; }
    .ttm-external-logins-title { font-size: 0.95rem; color: var(--text-bright); margin-bottom: 0.5rem; }
    .ttm-external-logins-buttons { display: flex; flex-wrap: wrap; gap: 8px; }
    .ttm-hr { border: none; border-top: 1px solid rgba(56, 189, 248, 0.2); margin: 0.75rem 0; }
</style>
