@model ttm3._0.Models.SendCodeViewModel
@{
    ViewBag.Title = "Gửi mã xác thực";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-mobile-alt"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Chọn phương thức nhận mã xác thực hai yếu tố.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm("SendCode", "Account", new { ReturnUrl = Model.ReturnUrl }, FormMethod.Post, new { @class = "ttm-form", role = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("rememberMe", Model.RememberMe)

                <div class="form-group">
                    <label>Chọn nhà cung cấp xác thực hai yếu tố</label>
                    @Html.DropDownListFor(m => m.SelectedProvider, Model.Providers, new { @class = "form-control" })
                </div>

                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-primary">
                        <i class="fas fa-paper-plane"></i>
                        <span>Gửi mã</span>
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
