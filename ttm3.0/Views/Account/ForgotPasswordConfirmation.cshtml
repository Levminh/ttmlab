@{
    ViewBag.Title = "Xác nhận quên mật khẩu";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-envelope"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Vui lòng kiểm tra email để đặt lại mật khẩu.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            <p class="ttm-status-msg">
                <i class="fas fa-check-circle"></i>
                Kiểm tra hộp thư (và thư mục spam) để nhận link đặt lại mật khẩu.
            </p>
            <a href="@Url.Action("Login", "Account")" class="ttm-btn ttm-btn-secondary">
                <i class="fas fa-sign-in-alt"></i>
                <span>Đăng nhập</span>
            </a>
        </div>
    </div>
</div>

<style>
    .ttm-status-msg {
        padding: 10px 14px;
        border-radius: 8px;
        background: rgba(74, 222, 128, 0.12);
        border: 1px solid rgba(74, 222, 128, 0.3);
        color: #86efac;
        font-size: 0.9rem;
        margin-bottom: 1.25rem;
    }
</style>
