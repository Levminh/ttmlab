@model ttm3._0.Models.RegisterViewModel
@{
    ViewBag.Title = "Đăng ký - THAO TRƯỜNG MẠNG";
    Layout = "~/Views/Shared/_LayoutMyLogin.cshtml";
}


<div class="relative min-h-screen overflow-hidden">
    <!-- Background gradient + overlay (đồng bộ với Login) -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-slate-800 via-slate-900 to-primary-800 opacity-80"></div>
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_#22c55e44,_transparent_60%),_radial-gradient(circle_at_bottom,_#38bdf844,_transparent_55%)]"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center px-4 py-10">
        <div class="mx-auto flex w-full max-w-5xl flex-col gap-8 lg:flex-row lg:items-center">
            <!-- Left: info -->
            <div class="w-full text-center lg:w-1/2 lg:text-left space-y-6">
                <div class="inline-flex items-center space-x-2 rounded-full bg-slate-800/70 px-3 py-1 text-xs font-medium text-slate-100 ring-1 ring-slate-500/70 backdrop-blur">
                    <span class="h-1.5 w-1.5 rounded-full bg-sky-400 animate-pulse"></span>
                    <span>Đăng ký tài khoản thao trường</span>
                </div>

                <h1 class="text-3xl font-bold tracking-tight text-slate-50 sm:text-4xl lg:text-5xl">
                    Tạo mới tài khoản
                    <span class="bg-gradient-to-r from-sky-400 to-emerald-400 bg-clip-text text-transparent">
                        THAO TRƯỜNG MẠNG
                    </span>
                </h1>

                <p class="max-w-xl text-sm text-slate-100/90 sm:text-base">
                    Tham gia các lớp huấn luyện, kịch bản tấn công – phòng thủ, và theo dõi tiến độ học tập
                    trong môi trường mô phỏng CrC500.
                </p>

                <ul class="space-y-2 text-xs text-slate-100/90 sm:text-sm">
                    <li class="flex items-center space-x-2">
                        <span class="h-5 w-5 rounded-full bg-emerald-500/10 text-emerald-400 flex items-center justify-center text-[11px]">
                            <i class="fas fa-check"></i>
                        </span>
                        <span>Gắn với lớp học, kịch bản thực chiến và kết quả thao trường.</span>
                    </li>
                    <li class="flex items-center space-x-2">
                        <span class="h-5 w-5 rounded-full bg-sky-500/10 text-sky-400 flex items-center justify-center text-[11px]">
                            <i class="fas fa-user-shield"></i>
                        </span>
                        <span>Phân quyền theo vai trò: Admin, Giảng viên, Sinh viên.</span>
                    </li>
                </ul>
            </div>

            <!-- Right: register card -->
            <div class="w-full lg:w-1/2">
                <div class="relative mx-auto max-w-md">
                    <div class="pointer-events-none absolute -inset-0.5 rounded-3xl bg-gradient-to-br from-sky-500/40 via-primary-500/30 to-emerald-500/40 opacity-70 blur-xl"></div>

                    <div class="relative overflow-hidden rounded-3xl bg-slate-900/75 p-6 shadow-2xl ring-1 ring-slate-600/70 backdrop-blur-md sm:p-8">
                        <div class="mb-6 flex items-center justify-between">
                            <div>
                                <h2 class="text-xl font-semibold text-slate-50 sm:text-2xl">
                                    Đăng ký tài khoản mới
                                </h2>
                                <p class="mt-1 text-xs text-slate-400 sm:text-sm">
                                    Điền thông tin cơ bản để bắt đầu sử dụng hệ thống.
                                </p>
                            </div>
                            <div class="hidden h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-tr from-sky-500 to-emerald-500 text-2xl text-white shadow-lg shadow-sky-900/40 sm:flex">
                                <i class="fas fa-user-plus"></i>
                            </div>
                        </div>

                        @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "space-y-5", role = "form" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary("", new { @class = "mb-3 rounded-lg border border-red-500/30 bg-red-500/5 px-3 py-2 text-xs text-red-300" })

                            <div class="space-y-1.5">
                                <label class="text-xs font-medium text-slate-200 sm:text-sm" for="Email">
                                    Email
                                </label>
                                @Html.TextBoxFor(
                                    m => m.Email,
                                    new
                                    {
                                        @class = "block w-full rounded-xl border border-slate-700/70 bg-slate-900/80 px-3 py-2.5 text-sm text-slate-50 placeholder-slate-500 shadow-sm outline-none ring-0 transition focus:border-sky-400/60 focus:ring-2 focus:ring-sky-500/40",
                                        @placeholder = "you@example.com"
                                    }
                                )
                            </div>

                            <div class="space-y-1.5">
                                <label class="text-xs font-medium text-slate-200 sm:text-sm" for="Password">
                                    Mật khẩu
                                </label>
                                @Html.PasswordFor(
                                    m => m.Password,
                                    new
                                    {
                                        @class = "block w-full rounded-xl border border-slate-700/70 bg-slate-900/80 px-3 py-2.5 text-sm text-slate-50 placeholder-slate-500 shadow-sm outline-none ring-0 transition focus:border-sky-400/60 focus:ring-2 focus:ring-sky-500/40",
                                        @placeholder = "Tối thiểu 6 ký tự"
                                    }
                                )
                            </div>

                            <div class="space-y-1.5">
                                <label class="text-xs font-medium text-slate-200 sm:text-sm" for="ConfirmPassword">
                                    Xác nhận mật khẩu
                                </label>
                                @Html.PasswordFor(
                                    m => m.ConfirmPassword,
                                    new
                                    {
                                        @class = "block w-full rounded-xl border border-slate-700/70 bg-slate-900/80 px-3 py-2.5 text-sm text-slate-50 placeholder-slate-500 shadow-sm outline-none ring-0 transition focus:border-sky-400/60 focus:ring-2 focus:ring-sky-500/40",
                                        @placeholder = "Nhập lại mật khẩu"
                                    }
                                )
                            </div>

                            <div class="pt-1">
                                <button type="submit"
                                        class="group flex w-full items-center justify-center space-x-2 rounded-xl bg-gradient-to-r from-sky-600 via-primary-500 to-emerald-500 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-sky-900/40 transition hover:from-sky-500 hover:to-emerald-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-400/70">
                                    <span>Hoàn tất đăng ký</span>
                                    <span class="transition-transform group-hover:translate-x-0.5">
                                        <i class="fas fa-arrow-right"></i>
                                    </span>
                                </button>
                            </div>

                            <div class="mt-4 flex items-center justify-center text-[11px] text-slate-400 sm:text-xs">
                                <span>Đã có tài khoản?</span>
                                <a href="@Url.Action("Login", "Account")"
                                   class="ml-1.5 font-medium text-sky-400 hover:text-sky-300">
                                    Đăng nhập
                                </a>
                            </div>
                        }

                        <p class="mt-6 text-center text-[11px] text-slate-500">
                            &copy; 2020 BAN CHỦ NHIỆM ĐỀ TÀI. THAO TRƯỜNG MẠNG CrC500.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
