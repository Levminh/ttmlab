@model ttm3._0.Models.VerifyCodeViewModel
@{
    ViewBag.Title = "Xác thực mã";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-shield-alt"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Nhập mã xác thực hai yếu tố.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm("VerifyCode", "Account", new { ReturnUrl = Model.ReturnUrl }, FormMethod.Post, new { @class = "ttm-form", role = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("provider", Model.Provider)
                @Html.Hidden("rememberMe", Model.RememberMe)
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                <div class="form-group">
                    @Html.LabelFor(m => m.Code)
                    @Html.TextBoxFor(m => m.Code, new { @class = "form-control", placeholder = "Mã xác thực" })
                    @Html.ValidationMessageFor(m => m.Code)
                </div>

                <div class="form-group">
                    <label class="ttm-checkbox-label">
                        @Html.CheckBoxFor(m => m.RememberBrowser)
                        @Html.DisplayNameFor(m => m.RememberBrowser)
                    </label>
                </div>

                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-primary">
                        <i class="fas fa-check"></i>
                        <span>Xác thực</span>
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .ttm-checkbox-label { font-weight: normal; cursor: pointer; display: flex; align-items: center; gap: 8px; }
</style>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
