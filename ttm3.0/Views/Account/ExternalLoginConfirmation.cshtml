@model ttm3._0.Models.ExternalLoginConfirmationViewModel
@{
    ViewBag.Title = "Đăng ký";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-link"></i></div>
                <div>
                    <h1 class="ttm-title">Liên kết tài khoản @ViewBag.LoginProvider</h1>
                    <p class="ttm-subtitle">Bạn đã xác thực bằng @ViewBag.LoginProvider. Nhập email để hoàn tất đăng ký.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm("ExternalLoginConfirmation", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "ttm-form", role = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                <div class="form-group">
                    @Html.LabelFor(m => m.Email)
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Email" })
                    @Html.ValidationMessageFor(m => m.Email)
                </div>

                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-primary">
                        <i class="fas fa-user-plus"></i>
                        <span>Hoàn tất đăng ký</span>
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
