@model ttm3._0.Models.ForgotPasswordViewModel
@{
    ViewBag.Title = "Quên mật khẩu";
}

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-key"></i></div>
                <div>
                    <h1 class="ttm-title">@ViewBag.Title</h1>
                    <p class="ttm-subtitle">Nhập email đăng ký để nhận link đặt lại mật khẩu.</p>
                </div>
            </div>
        </div>
        <div class="ttm-body">
            @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { @class = "ttm-form", role = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                <div class="form-group">
                    @Html.LabelFor(m => m.Email)
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Email của bạn" })
                    @Html.ValidationMessageFor(m => m.Email)
                </div>

                <div class="ttm-form-actions">
                    <button type="submit" class="ttm-btn ttm-btn-primary">
                        <i class="fas fa-paper-plane"></i>
                        <span>Gửi link</span>
                    </button>
                    <a href="@Url.Action("Login", "Account")" class="ttm-btn ttm-btn-secondary">
                        <i class="fas fa-arrow-left"></i>
                        <span>Quay lại đăng nhập</span>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
