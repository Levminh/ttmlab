@using ttm3._0.Models
@model LoginViewModel
@{
    ViewBag.Title = "Đăng nhập - THAO TRƯỜNG MẠNG";
    Layout = "~/Views/Shared/_LayoutMyLogin.cshtml";
}
<link href="~/Content/login.css" rel="stylesheet" />

<div class="main">
    <h1>Thao trường mạng CrC500</h1>
    <div class="login-form">
        <div class="login-left">
            <div class="logo">
                <img src="~/Content/images/img1.jpg" alt="" />
                <h2>Welcome </h2>
                <p>HỆ THỐNG QUẢN LÝ ĐÀO TẠO</p>
            </div>
            <div class="social-icons">
                <ul>
                    <li><a href="#"><img src="~/Content/images/i1.png" alt="" /></a></li>
                    <li><a href="#" class="twt"><img src="~/Content/images/i2.png" alt="" /></a></li>
                    <li><a href="#" class="ggl"><img src="~/Content/images/i3.png" alt="" /></a></li>
                </ul>
            </div>
        </div>
        <div class="login-right">
            <div class="sap_tabs">
                <div id="horizontalTab" style="display: block; width: 100%; margin: 0px;">
                    <ul class="resp-tabs-list">
                        <li class="resp-tab-item" aria-controls="tab_item-0" role="tab"><span>Đăng nhập</span></li>
                    </ul>
                    <div class="clear"> </div>
                    <div class="resp-tabs-container">
                        <div class="tab-1 resp-tab-content" aria-labelledby="tab_item-0">
                            <div class="login-top">
                                @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", @placeholder = "Tên đăng nhập" })
                                    @Html.PasswordFor(m => m.Password, new { @class = "password", @placeholder = "Mật khẩu" })


                                    <div class="login-text">
                                        <ul>
                                            <li>
                                                @Html.CheckBoxFor(m => m.RememberMe)
                                                @Html.DisplayNameFor(m => m.RememberMe)
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="login-bottom login-bottom1">
                                        <div class="submit">
                                            <input type="submit" value="LOGIN" />
                                        </div>
                                        <div class="clear"></div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="clear"> </div>
    </div>
</div>
<!--//main -->
<div class="copyright">
    <p> &copy; 2020 BAN CHỦ NHIỆM ĐỀ TÀI. All rights reserved | Design by TANTD</p>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script type="application/x-javascript"> addEventListener("load", function() { setTimeout(hideURLbar, 0); }, false); function hideURLbar(){ window.scrollTo(0,1); } </script>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/easyResponsiveTabs.js" type="text/javascript"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('#horizontalTab').easyResponsiveTabs({
                type: 'default', //Types: default, vertical, accordion
                width: 'auto', //auto or any width like 600px
                fit: true   // 100% fit in a container
            });
        });
    </script>
}