@using ttm3._0.Models
@model LoginViewModel
@{
    ViewBag.Title = "Đăng nhập - THAO TRƯỜNG MẠNG";
    Layout = "~/Views/Shared/_LayoutMyLogin.cshtml";
}

<div class="relative min-h-screen overflow-hidden">
    <!-- Background gradient + overlay -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-slate-800 via-slate-900 to-primary-800 opacity-80"></div>
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_#22c55e44,_transparent_60%),_radial-gradient(circle_at_bottom,_#38bdf844,_transparent_55%)]"></div>

    <!-- Subtle animated grid -->
    <div class="pointer-events-none absolute inset-0 opacity-10">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,_#64748b33_1px,transparent_1px),linear-gradient(to_bottom,_#64748b33_1px,transparent_1px)] bg-[size:60px_60px] animate-pulse"></div>
    </div>

    <div class="relative z-10 flex min-h-screen items-center justify-center px-4 py-10">
        <div class="mx-auto flex w-full max-w-5xl flex-col gap-8 lg:flex-row lg:items-center">
            <!-- Left: branding / intro -->
            <div class="w-full text-center lg:w-1/2 lg:text-left space-y-6">
                <div class="inline-flex items-center space-x-2 rounded-full bg-slate-800/70 px-3 py-1 text-xs font-medium text-slate-100 ring-1 ring-slate-500/70 backdrop-blur">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                    <span>Thao trường mạng CrC500</span>
                </div>

                <h1 class="text-3xl font-bold tracking-tight text-slate-50 sm:text-4xl lg:text-5xl">
                    Không gian mô phỏng
                    <span class="bg-gradient-to-r from-emerald-400 to-sky-400 bg-clip-text text-transparent">
                        tác chiến mạng
                    </span>
                </h1>

                <p class="max-w-xl text-sm text-slate-100/90 sm:text-base">
                    Hệ thống quản lý đào tạo, mô phỏng kịch bản tấn công phòng thủ trong môi trường mạng CrC500.
                    Đăng nhập để tham gia lớp học, thao trường, và theo dõi kết quả huấn luyện.
                </p>

                <div class="flex flex-wrap items-center justify-center gap-4 text-xs text-slate-100/90 sm:justify-start">
                    <div class="flex items-center space-x-2 rounded-xl bg-slate-800/70 px-3 py-2 ring-1 ring-slate-500/70 backdrop-blur">
                        <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-emerald-500/10 text-emerald-400">
                            <i class="fas fa-shield-alt"></i>
                        </span>
                        <div>
                            <div class="font-semibold text-slate-100">An toàn & bảo mật</div>
                            <div class="text-[11px] text-slate-400">Xác thực chặt chẽ, phân quyền theo vai trò</div>
                        </div>
                    </div>
                    <div class="flex items-center space-x-2 rounded-xl bg-slate-800/70 px-3 py-2 ring-1 ring-slate-500/70 backdrop-blur">
                        <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-sky-500/10 text-sky-400">
                            <i class="fas fa-network-wired"></i>
                        </span>
                        <div>
                            <div class="font-semibold text-slate-100">Môi trường mô phỏng thực chiến</div>
                            <div class="text-[11px] text-slate-400">Tập trung vào thực hành & kịch bản</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: login card -->
            <div class="w-full lg:w-1/2">
                <div class="relative mx-auto max-w-md">
                    <!-- Glow -->
                    <div class="pointer-events-none absolute -inset-0.5 rounded-3xl bg-gradient-to-br from-emerald-400/40 via-sky-500/30 to-primary-700/40 opacity-70 blur-xl"></div>

                    <div class="relative overflow-hidden rounded-3xl bg-slate-900/75 p-6 shadow-2xl ring-1 ring-slate-600/70 backdrop-blur-md sm:p-8">
                        <div class="mb-6 flex items-center justify-between">
                            <div>
                                <h2 class="text-xl font-semibold text-slate-50 sm:text-2xl">
                                    Đăng nhập hệ thống
                                </h2>
                                <p class="mt-1 text-xs text-slate-400 sm:text-sm">
                                    Sử dụng tài khoản được cấp để truy cập thao trường.
                                </p>
                            </div>
                            <div class="hidden h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-tr from-primary-600 to-emerald-500 text-2xl text-white shadow-lg shadow-primary-900/40 sm:flex">
                                <i class="fas fa-bolt"></i>
                            </div>
                        </div>

                        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "space-y-5", role = "form" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "mb-3 rounded-lg border border-red-500/30 bg-red-500/5 px-3 py-2 text-xs text-red-300" })

                            <div class="space-y-1.5">
                                <label class="flex items-center justify-between text-xs font-medium text-slate-200 sm:text-sm" for="UserName">
                                    <span>Tên đăng nhập</span>
                                </label>
                                @Html.TextBoxFor(
                                    m => m.UserName,
                                    new
                                    {
                                        @class = "block w-full rounded-xl border border-slate-700/70 bg-slate-900/80 px-3 py-2.5 text-sm text-slate-50 placeholder-slate-500 shadow-sm outline-none ring-0 transition focus:border-emerald-400/60 focus:ring-2 focus:ring-emerald-500/40",
                                        @placeholder = "Ví dụ: sinhvien01"
                                    }
                                )
                            </div>

                            <div class="space-y-1.5">
                                <div class="flex items-center justify-between text-xs font-medium text-slate-200 sm:text-sm">
                                    <label for="Password">Mật khẩu</label>
                                    <a href="@Url.Action("ForgotPassword", "Account")" class="text-[11px] font-normal text-sky-400 hover:text-sky-300">
                                        Quên mật khẩu?
                                    </a>
                                </div>
                                @Html.PasswordFor(
                                    m => m.Password,
                                    new
                                    {
                                        @class = "block w-full rounded-xl border border-slate-700/70 bg-slate-900/80 px-3 py-2.5 text-sm text-slate-50 placeholder-slate-500 shadow-sm outline-none ring-0 transition focus:border-emerald-400/60 focus:ring-2 focus:ring-emerald-500/40",
                                        @placeholder = "Nhập mật khẩu của bạn"
                                    }
                                )
                            </div>

                            <div class="flex items-center justify-between pt-1 text-xs sm:text-sm">
                                <label class="inline-flex items-center space-x-2 text-slate-300">
                                    @Html.CheckBoxFor(m => m.RememberMe, new { @class = "h-4 w-4 rounded border-slate-600 bg-slate-900 text-emerald-500 focus:ring-emerald-500" })
                                    <span>@Html.DisplayNameFor(m => m.RememberMe)</span>
                                </label>
                            </div>

                            <div class="pt-1">
                                <button type="submit"
                                        class="group flex w-full items-center justify-center space-x-2 rounded-xl bg-gradient-to-r from-primary-600 via-primary-500 to-emerald-500 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-primary-900/40 transition hover:from-primary-500 hover:to-emerald-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400/70">
                                    <span>Đăng nhập</span>
                                    <span class="transition-transform group-hover:translate-x-0.5">
                                        <i class="fas fa-arrow-right"></i>
                                    </span>
                                </button>
                            </div>

                            <div class="mt-4 flex items-center space-x-3 text-[11px] text-slate-400 sm:text-xs">
                                <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-700/80 to-transparent"></div>
                                <span>Chưa có tài khoản?</span>
                                <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-700/80 to-transparent"></div>
                            </div>

                            <div class="flex items-center justify-center pt-1">
                                <a href="@Url.Action("Register", "Account")"
                                   class="inline-flex items-center justify-center rounded-xl border border-slate-700/80 bg-slate-900/60 px-4 py-2 text-xs font-medium text-slate-100 shadow-sm transition hover:border-emerald-400/60 hover:bg-slate-900/80">
                                    <span class="mr-2 h-6 w-6 rounded-full bg-slate-800/80 text-[11px] leading-6 text-center text-emerald-400">
                                        +
                                    </span>
                                    Đăng ký tài khoản mới
                                </a>
                            </div>
                        }

                        <p class="mt-6 text-center text-[11px] text-slate-500">
                            &copy; 2020 BAN CHỦ NHIỆM ĐỀ TÀI. Thiết kế cho hệ thống Thao trường mạng.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}