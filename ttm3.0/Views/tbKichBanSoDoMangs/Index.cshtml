@model IEnumerable<ttm3._0.Models.tbKichBanSoDoMang>

@{
    ViewBag.Title = "Danh sách sơ đồ mạng trong kịch bản";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/datatables.min.css" rel="stylesheet" />

<div class="ttm-page">
    <div class="ttm-card">
        <div class="ttm-header">
            <div class="ttm-header-left">
                <div class="ttm-icon"><i class="fas fa-project-diagram"></i></div>
                <div>
                    <h1 class="ttm-title">@(ViewBag.TieuDe ?? ViewBag.Title)</h1>
                    <p class="ttm-subtitle">Liên kết sơ đồ mạng với kịch bản thực hành.</p>
                </div>
            </div>
            <div>
                <a href="@Url.Action("Create", "tbKichBanSoDoMangs", new { IdKichBan = ViewBag.IdKichBan })" class="ttm-btn ttm-btn-add">
                    <i class="fas fa-plus"></i>
                    <span>Bổ sung sơ đồ mạng</span>
                </a>
            </div>
        </div>
        <div class="ttm-body">
            <div class="table-responsive ttm-table-wrap">
                <table class="ttm-table display table table-bordered" id="table_project">
                    <thead>
                        <tr>
                            <th class="ttm-col-tt" style="width:40px;">TT</th>
                            <th>@Html.DisplayNameFor(model => model.tbSoDoMang.Ten)</th>
                            <th class="ttm-col-actions" style="min-width:80px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ttm-col-tt"></td>
                                <td class="editable-select" id="@item.Id">@Html.DisplayFor(modelItem => item.tbSoDoMang.Ten)</td>
                                <td class="ttm-col-actions">
                                    <a href="@Url.Action("Delete", "tbKichBanSoDoMangs", new { id = item.Id })" class="ttm-act ttm-act-del" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery-1.12.4.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/Scripts/datatables.min.js"></script>
    <script src="~/Scripts/jquery.jeditable.js"></script>
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            var t = $('#table_project').DataTable({
                "pageLength": 50,
                "columnDefs": [{ "searchable": false, "orderable": false, "targets": 0 }, { "orderable": false, "targets": -1 }],
                "order": [[1, 'asc']],
                "language": {
                    "search": "Tìm kiếm:",
                    "lengthMenu": "Hiển thị _MENU_ dòng",
                    "info": "Đang xem _START_–_END_ / _TOTAL_ dòng",
                    "paginate": { "first": "Đầu", "last": "Cuối", "next": "Sau", "previous": "Trước" }
                }
            });
            t.on('order.dt search.dt', function () {
                t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) { cell.innerHTML = i + 1; });
            }).draw();
            $(".editable-select").editable("/tbKichBanSoDoMangs/UpdateSoDoMang", {
                type: "select",
                loadurl: "/tbKichBanSoDoMangs/LoadSoDoMangAsync",
                loadtype: 'GET',
                loaddata: null,
                submitdata: "OK",
                style: "inherit"
            });
        });
    </script>
}
